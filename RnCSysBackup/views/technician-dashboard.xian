        .form-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.8), 0 0 60px rgba(118, 75, 162, 0.6), 0 15px 35px rgba(0, 0, 0, 0.4);
