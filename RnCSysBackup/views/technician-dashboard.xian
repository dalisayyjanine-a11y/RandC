<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Technician Dashboard - RNC System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        /* Enhanced Animated Background with Intense Glow */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .bg-gradient {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab, #f702a8, #0af);
            background-size: 400% 400%;
            animation: gradientBG 8s ease infinite;
            opacity: 0.25;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Ultra Glow Orbs */
        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(50px);
            animation: orbFloat 10s ease-in-out infinite;
        }

        .glow-orb-1 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(102, 126, 234, 0.5) 0%, transparent 70%);
            top: -50px;
            left: -50px;
        }

        .glow-orb-2 {
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(118, 75, 162, 0.5) 0%, transparent 70%);
            bottom: -50px;
            right: -50px;
            animation-delay: -5s;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(20px, -20px) scale(1.1); }
        }

        /* Floating Particles */
        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .particle {
            position: absolute;
            width: 5px;
            height: 5px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 50%;
            animation: float 5s ease-in-out infinite;
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.6);
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
            50% { transform: translateY(-80px) rotate(180deg); opacity: 1; }
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            min-height: 100vh;
            padding: 25px 0;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.2);
            transition: all 0.3s ease;
            z-index: 100;
            overflow-y: auto;
        }

        .sidebar.collapsed {
            left: -280px;
        }

        .sidebar-header {
            text-align: center;
            padding: 0 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }

        .sidebar-header .logo {
            font-size: 48px;
            display: block;
            margin-bottom: 10px;
            animation: bounce 2s ease-in-out infinite, iconGlow 2s ease-in-out infinite alternate;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        @keyframes iconGlow {
            from { filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.5)); }
            to { filter: drop-shadow(0 0 25px rgba(255, 255, 255, 0.9)); }
        }

        .sidebar-header h2 {
            font-size: 1.6em;
            color: white;
            text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sidebar-header p {
            font-size: 0.8em;
            color: rgba(255, 255, 255, 0.7);
            margin-top: 5px;
        }

        .sidebar-menu {
            list-style: none;
        }

        .sidebar-menu li {
            margin-bottom: 5px;
        }

        .sidebar-menu li a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 25px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: all 0.3s;
            border-left: 4px solid transparent;
            font-weight: 500;
            cursor: pointer;
        }

        .sidebar-menu li a:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-left-color: #23a6d5;
            text-shadow: 0 0 10px rgba(102, 126, 234, 0.5);
        }

        .sidebar-menu li a.active {
            background: rgba(102, 126, 234, 0.2);
            color: white;
            border-left-color: #f702a8;
            text-shadow: 0 0 15px rgba(247, 2, 168, 0.5);
        }

        .menu-icon {
            font-size: 1.3em;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 25px;
            transition: margin 0.3s ease;
            position: relative;
            z-index: 1;
            overflow-y: auto;
            height: 100vh;
        }

        .main-content.expanded {
            margin-left: 0;
        }

        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            padding: 20px 25px;
            border-radius: 15px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.15);
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: fadeInDown 0.6s ease-out;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header h1 {
            color: white;
            font-size: 1.8em;
            text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .header p {
            color: rgba(255, 255, 255, 0.7);
            margin-top: 5px;
        }

        .tech-info {
            text-align: right;
        }

        .tech-info p {
            color: rgba(255, 255, 255, 0.9);
            margin: 3px 0;
            font-size: 0.9em;
        }

        .tech-info strong {
            color: #23a6d5;
            text-shadow: 0 0 10px rgba(35, 166, 213, 0.5);
        }

        /* Content Sections */
        .content-section {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .content-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .section-title {
            color: white;
            font-size: 1.6em;
            margin-bottom: 20px;
            text-shadow: 0 0 15px rgba(102, 126, 234, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 25px;
            transition: all 0.3s ease;
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.15);
            animation: fadeInUp 0.6s ease-out backwards, techCardGlow 3s ease-in-out infinite;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2, #f702a8);
            background-size: 200% 100%;
            animation: gradientMove 3s ease infinite;
            opacity: 0.8;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.08) 50%, transparent 60%);
            transform: rotate(45deg);
            animation: shimmer 3s ease-in-out infinite;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

        @keyframes gradientMove { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        @keyframes shimmer { 0% { transform: translateX(-100%) rotate(45deg); } 100% { transform: translateX(100%) rotate(45deg); } }
        @keyframes techCardGlow { 0%, 100% { box-shadow: 0 0 30px rgba(102, 126, 234, 0.15), 0 0 20px rgba(102, 126, 234, 0.1); } 50% { box-shadow: 0 0 40px rgba(102, 126, 234, 0.25), 0 0 30px rgba(118, 75, 162, 0.15); } }

        .stat-card:nth-child(1) { animation-delay: 0.1s; }
        .stat-card:nth-child(2) { animation-delay: 0.2s; }
        .stat-card:nth-child(3) { animation-delay: 0.3s; }
        .stat-card:nth-child(4) { animation-delay: 0.4s; }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0 50px rgba(102, 126, 234, 0.4), 0 0 70px rgba(118, 75, 162, 0.3), 0 0 90px rgba(247, 2, 168, 0.2);
            border-color: rgba(255, 255, 255, 0.3);
            animation: none;
        }

        .stat-card:hover::after { opacity: 1; }

        .stat-card .stat-icon {
            font-size: 40px;
            margin-bottom: 15px;
            display: block;
            animation: iconFloat 3s ease-in-out infinite;
        }

        @keyframes iconFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }

        .stat-card .stat-value {
            font-size: 2.5em;
            font-weight: 700;
            color: white;
            text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
            animation: valueGlow 2s ease-in-out infinite;
        }

        @keyframes valueGlow { 0%, 100% { text-shadow: 0 0 20px rgba(255, 255, 255, 0.3); } 50% { text-shadow: 0 0 30px rgba(255, 255, 255, 0.5), 0 0 40px rgba(102, 126, 234, 0.3); } }

        .stat-card .stat-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9em;
            margin-top: 5px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Welcome Card */
        .welcome-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 30px;
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.2);
            animation: fadeInUp 0.6s ease-out;
        }

        .welcome-card h2 {
            color: white;
            font-size: 1.8em;
            margin-bottom: 15px;
            text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
        }

        .welcome-card p {
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.8;
            font-size: 1.1em;
        }

        .welcome-card .specialty-badge {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 8px 20px;
            border-radius: 25px;
            margin-top: 20px;
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
        }

        /* Profile Card */
        .profile-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 30px;
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.2);
            animation: fadeInUp 0.6s ease-out;
        }

        .profile-card h3 {
            color: white;
            font-size: 1.4em;
            margin-bottom: 20px;
            text-shadow: 0 0 15px rgba(102, 126, 234, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .profile-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .profile-item:last-child {
            border-bottom: none;
        }

        .profile-item label {
            color: rgba(255, 255, 255, 0.7);
            font-weight: 500;
        }

        .profile-item span {
            color: white;
            font-weight: 600;
        }

        /* Notification - Glowing Styles */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 18px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            z-index: 2000;
            animation: slideInNotification 0.5s ease-out, notificationGlow 2s ease-in-out infinite;
            backdrop-filter: blur(10px);
            border: 2px solid;
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 400px;
            position: relative;
        }

        .notification::before {
            content: '✓';
            font-size: 22px;
            font-weight: bold;
            filter: drop-shadow(0 0 6px rgba(34, 197, 94, 0.8));
        }

        .notification.success {
            background: rgba(34, 197, 94, 0.15);
            color: #22c55e;
            border-color: rgba(34, 197, 94, 0.5);
            box-shadow: 
                0 0 20px rgba(34, 197, 94, 0.6),
                0 0 40px rgba(34, 197, 94, 0.4),
                0 0 60px rgba(34, 197, 94, 0.3),
                0 10px 40px rgba(34, 197, 94, 0.2);
        }

        .notification.error {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.5);
            box-shadow: 
                0 0 20px rgba(239, 68, 68, 0.6),
                0 0 40px rgba(239, 68, 68, 0.4),
                0 0 60px rgba(239, 68, 68, 0.3),
                0 10px 40px rgba(239, 68, 68, 0.2);
            animation: slideInNotification 0.5s ease-out, errorGlow 2s ease-in-out infinite;
        }

        .notification.error::before {
            content: '✕';
            filter: drop-shadow(0 0 6px rgba(239, 68, 68, 0.8));
        }

        .notification.info {
            background: rgba(59, 130, 246, 0.15);
            color: #3b82f6;
            border-color: rgba(59, 130, 246, 0.5);
            box-shadow: 
                0 0 20px rgba(59, 130, 246, 0.6),
                0 0 40px rgba(59, 130, 246, 0.4),
                0 0 60px rgba(59, 130, 246, 0.3),
                0 10px 40px rgba(59, 130, 246, 0.2);
            animation: slideInNotification 0.5s ease-out, infoGlow 2s ease-in-out infinite;
        }

        .notification.info::before {
            content: 'ℹ️';
            filter: drop-shadow(0 0 6px rgba(59, 130, 246, 0.8));
        }

        .notification.warning {
            background: rgba(249, 115, 22, 0.15);
            color: #f97316;
            border-color: rgba(249, 115, 22, 0.5);
            box-shadow: 
                0 0 20px rgba(249, 115, 22, 0.6),
                0 0 40px rgba(249, 115, 22, 0.4),
                0 0 60px rgba(249, 115, 22, 0.3),
                0 10px 40px rgba(249, 115, 22, 0.2);
            animation: slideInNotification 0.5s ease-out, warningGlow 2s ease-in-out infinite;
        }

        .notification.warning::before {
            content: '⚠️';
            filter: drop-shadow(0 0 6px rgba(249, 115, 22, 0.8));
        }

        .notification::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 12px;
            border: 2px solid rgba(255, 255, 255, 0.2);
            animation: glowBorder 2s ease-in-out infinite;
            pointer-events: none;
        }

        @keyframes slideInNotification {
            from {
                opacity: 0;
                transform: translateX(400px) rotate(5deg);
            }
            to {
                opacity: 1;
                transform: translateX(0) rotate(0);
            }
        }

        @keyframes notificationGlow {
            0%, 100% {
                box-shadow: 
                    0 0 20px rgba(34, 197, 94, 0.6),
                    0 0 40px rgba(34, 197, 94, 0.4),
                    0 0 60px rgba(34, 197, 94, 0.3);
            }
            50% {
                box-shadow: 
                    0 0 30px rgba(34, 197, 94, 0.8),
                    0 0 60px rgba(34, 197, 94, 0.6),
                    0 0 90px rgba(34, 197, 94, 0.4);
            }
        }

        @keyframes errorGlow {
            0%, 100% {
                box-shadow: 
                    0 0 20px rgba(239, 68, 68, 0.6),
                    0 0 40px rgba(239, 68, 68, 0.4),
                    0 0 60px rgba(239, 68, 68, 0.3);
            }
            50% {
                box-shadow: 
                    0 0 30px rgba(239, 68, 68, 0.8),
                    0 0 60px rgba(239, 68, 68, 0.6),
                    0 0 90px rgba(239, 68, 68, 0.4);
            }
        }

        @keyframes infoGlow {
            0%, 100% {
                box-shadow: 
                    0 0 20px rgba(59, 130, 246, 0.6),
                    0 0 40px rgba(59, 130, 246, 0.4),
                    0 0 60px rgba(59, 130, 246, 0.3);
            }
            50% {
                box-shadow: 
                    0 0 30px rgba(59, 130, 246, 0.8),
                    0 0 60px rgba(59, 130, 246, 0.6),
                    0 0 90px rgba(59, 130, 246, 0.4);
            }
        }

        @keyframes warningGlow {
            0%, 100% {
                box-shadow: 
                    0 0 20px rgba(249, 115, 22, 0.6),
                    0 0 40px rgba(249, 115, 22, 0.4),
                    0 0 60px rgba(249, 115, 22, 0.3);
            }
            50% {
                box-shadow: 
                    0 0 30px rgba(249, 115, 22, 0.8),
                    0 0 60px rgba(249, 115, 22, 0.6),
                    0 0 90px rgba(249, 115, 22, 0.4);
            }
        }

        @keyframes glowBorder {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.8; }
        }

        @keyframes slideOut {
            to {
                opacity: 0;
                transform: translateX(400px) rotate(-5deg);
            }
        }

        @keyframes notificationSlideIn {
            from {
                opacity: 0;
                transform: translateX(-50%) translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
        }

        @keyframes notificationSlideOut {
            from {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
            to {
                opacity: 0;
                transform: translateX(-50%) translateY(-20px);
            }
        }

        @keyframes notificationGlowPulse {
            0%, 100% {
                box-shadow: 0 0 30px rgba(34, 197, 94, 0.5), 0 8px 25px rgba(0,0,0,0.3);
            }
            50% {
                box-shadow: 0 0 40px rgba(34, 197, 94, 0.8), 0 8px 25px rgba(0,0,0,0.3);
            }
        }

        /* Burger Menu Button */
        .burger-menu {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1001;
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            transition: all 0.3s ease;
        }

        .burger-menu:hover {
            background: rgba(255, 255, 255, 0.2);
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
        }

        .burger-menu span {
            width: 25px;
            height: 3px;
            background: white;
            border-radius: 3px;
            transition: all 0.3s ease;
        }

        .burger-menu.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .burger-menu.active span:nth-child(2) {
            opacity: 0;
        }

        .burger-menu.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        /* Job Orders Table */
        .jobs-table-container {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 25px;
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.2);
            overflow-x: auto;
            animation: fadeInUp 0.6s ease-out;
        }

        .jobs-table-container h3 {
            color: white;
            font-size: 1.4em;
            margin-bottom: 20px;
            text-shadow: 0 0 15px rgba(102, 126, 234, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .jobs-table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        .jobs-table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
        }

        .jobs-table thead {
            background: rgba(102, 126, 234, 0.2);
            border: 1px solid rgba(102, 126, 234, 0.3);
        }

        .jobs-table th {
            padding: 15px 12px;
            text-align: left;
            color: #23a6d5;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85em;
            letter-spacing: 1px;
            border-right: 1px solid rgba(102, 126, 234, 0.3);
        }

        .jobs-table th:last-child {
            border-right: none;
        }

        .jobs-table tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

        .jobs-table tbody tr:hover {
            background: rgba(102, 126, 234, 0.1);
            border-bottom-color: rgba(35, 166, 213, 0.3);
        }

        .jobs-table td {
            padding: 14px 12px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9em;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
        }

        .jobs-table td:last-child {
            border-right: none;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            border: 1px solid;
            background: rgba(100, 150, 200, 0.2);
            color: #6496c8;
            border-color: rgba(100, 150, 200, 0.5);
        }

        .status-badge[data-status="Submitted"] {
            background: rgba(100, 150, 200, 0.2);
            color: #6496c8;
            border-color: rgba(100, 150, 200, 0.5);
        }

        .status-badge[data-status="Diagnostic"] {
            background: rgba(250, 200, 20, 0.2);
            color: #fac814;
            border-color: rgba(250, 200, 20, 0.5);
        }

        .status-badge[data-status="Pending"] {
            background: rgba(255, 150, 0, 0.2);
            color: #ff9600;
            border-color: rgba(255, 150, 0, 0.5);
        }

        .status-badge[data-status="In Progress"] {
            background: rgba(35, 166, 213, 0.2);
            color: #23a6d5;
            border-color: rgba(35, 166, 213, 0.5);
        }

        .status-badge[data-status="Checking"] {
            background: rgba(247, 2, 168, 0.2);
            color: #f702a8;
            border-color: rgba(247, 2, 168, 0.5);
        }

        .status-badge[data-status="Completed"] {
            background: rgba(34, 100, 50, 0.2);
            color: #226432;
            border-color: rgba(34, 100, 50, 0.5);
        }

        .status-badge[data-status="Request Submitted"] {
            background: rgba(100, 150, 200, 0.2);
            color: #6496c8;
            border-color: rgba(100, 150, 200, 0.5);
        }

        /* Status Glow Animation */
        .status-glow {
            animation: statusGlow 2s ease-in-out infinite;
            box-shadow: 0 0 10px currentColor;
        }

        @keyframes statusGlow {
            0%, 100% {
                box-shadow: 0 0 5px currentColor;
            }
            50% {
                box-shadow: 0 0 20px currentColor, 0 0 30px currentColor;
            }
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-view {
            padding: 6px 12px;
            background: rgba(35, 166, 213, 0.2);
            border: 1px solid rgba(35, 166, 213, 0.5);
            color: #23a6d5;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            font-size: 0.85em;
        }

        .btn-view:hover {
            background: rgba(35, 166, 213, 0.3);
            box-shadow: 0 0 10px rgba(35, 166, 213, 0.3);
        }

        .empty-message {
            text-align: center;
            padding: 40px 20px;
            color: rgba(255, 255, 255, 0.6);
            font-style: italic;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                width: 240px;
            }

            .sidebar.collapsed {
                left: -240px;
            }

            .main-content {
                margin-left: 240px;
            }

            .main-content.expanded {
                margin-left: 0;
            }

            .header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

            .tech-info {
                text-align: center;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Background Animation -->
    <div class="bg-animation">
        <div class="bg-gradient"></div>
        <div class="glow-orb glow-orb-1"></div>
        <div class="glow-orb glow-orb-2"></div>
        <div class="particles" id="particles"></div>
    </div>

    <!-- Burger Menu Button -->
    <button class="burger-menu" id="burgerMenu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Sidebar Navigation -->
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <span class="logo">🔧</span>
            <h2>RNC</h2>
            <p>Technician Panel</p>
        </div>
        <ul class="sidebar-menu">
            <li><a id="menu-dashboard" class="menu-link active"><span class="menu-icon">📊</span> Dashboard</a></li>
            <li><a id="menu-profile" class="menu-link"><span class="menu-icon">👤</span> My Profile</a></li>
            <li><a id="menu-submitted" class="menu-link"><span class="menu-icon">📋</span> Submitted Orders</a></li>
            <li><a id="menu-diagnostics" class="menu-link"><span class="menu-icon">🔍</span> Diagnostics</a></li>
            <li><a id="menu-rto" class="menu-link"><span class="menu-icon">📤</span> Return to Owner</a></li>
            <li><a href="/logbook" class="menu-link"><span class="menu-icon">📚</span> LogBook</a></li>
            <li><a href="/job-order-form" class="menu-link"><span class="menu-icon">➕</span> New Job Order</a></li>
            <li><a href="/logout" class="menu-link"><span class="menu-icon">🚪</span> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        <div class="header">
            <div>
                <h1>Technician Panel</h1>
                <p>Manage Your Tasks</p>
            </div>
            <div class="tech-info">
                <p><strong>Welcome!</strong></p>
                <p><%- technician.email %></p>
            </div>
        </div>

        <!-- Dashboard Overview Section -->
        <div id="dashboard" class="content-section active">
            <h2 class="section-title">📊 Dashboard Overview</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <span class="stat-icon">✅</span>
                    <div class="stat-value">0</div>
                    <div class="stat-label">Completed Jobs</div>
                </div>
                <div class="stat-card">
                    <span class="stat-icon">⏳</span>
                    <div class="stat-value">0</div>
                    <div class="stat-label">Pending Jobs</div>
                </div>
                <div class="stat-card">
                    <span class="stat-icon">⭐</span>
                    <div class="stat-value">5.0</div>
                    <div class="stat-label">Rating</div>
                </div>
                <div class="stat-card">
                    <span class="stat-icon">📅</span>
                    <div class="stat-value">0</div>
                    <div class="stat-label">This Month</div>
                </div>
            </div>

            <div class="welcome-card">
                <h2>Welcome to RNC System!</h2>
                <p>You are logged in as a technician. Use the navigation menu to browse your dashboard and profile. 
                Your specialty: <strong><%- technician.specialty || 'General Repair' %></strong></p>
                <div class="specialty-badge">
                    <%- technician.specialty || 'General Repair' %>
                </div>
            </div>
        </div>

        <!-- Profile Section -->
        <div id="profile" class="content-section">
            <h2 class="section-title">👤 My Profile</h2>
            <div class="profile-card">
                <h3>Technician Information</h3>
                <div class="profile-item">
                    <label>Name:</label>
                    <span><%- technician.name %></span>
                </div>
                <div class="profile-item">
                    <label>Email:</label>
                    <span><%- technician.email %></span>
                </div>
                <div class="profile-item">
                    <label>Phone:</label>
                    <span><%- technician.phone || 'Not set' %></span>
                </div>
                <div class="profile-item">
                    <label>Specialty:</label>
                    <span><%- technician.specialty || 'General Repair' %></span>
                </div>
                <div class="profile-item">
                    <label>Status:</label>
                    <span><%- technician.status %></span>
                </div>
                <div class="profile-item">
                    <label>Member Since:</label>
                    <span><%- technician.createdAt ? new Date(technician.createdAt).toLocaleDateString() : 'N/A' %></span>
                </div>
            </div>
        </div>

        <!-- Submitted Orders Section -->
        <div id="submitted" class="content-section">
            <h2 class="section-title">📋 Submitted Orders</h2>
            <div class="jobs-table-container">
                <h3>Your Job Orders</h3>
                <div class="jobs-table-wrapper">
                    <table class="jobs-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Customer</th>
                                <th>Device</th>
                                <th>Brand/Model</th>
                                <th>Problems</th>
                                <th>Submitted Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="jobOrdersBody">
                            <tr>
                                <td colspan="7" class="empty-message">Loading job orders...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Diagnostics Section -->
        <div id="diagnostics" class="content-section">
            <h2 class="section-title">🔍 Diagnostics</h2>
            <div style="margin-bottom: 20px;">
                <a class="btn-new-diagnostic" onclick="openCreateDiagnosticModal(); return false;" style="display: inline-block; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 12px 25px; border-radius: 8px; text-decoration: none; font-weight: 600; transition: all 0.3s; cursor: pointer;">+ Create New Diagnostic</a>
            </div>
            <div class="diagnostics-table-container">
                <table class="jobs-table">
                    <thead>
                        <tr>
                            <th>Diagnostic ID</th>
                            <th>Job Order</th>
                            <th>Customer</th>
                            <th>Problem</th>
                            <th>Device</th>
                            <th>Status</th>
                            <th>Submitted Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="diagnosticsBody">
                        <tr>
                            <td colspan="8" class="empty-message">Loading diagnostics...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Create floating particles
        const particlesContainer = document.getElementById('particles');
        const particleCount = 25;

        for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 5 + 's';
            particle.style.animationDuration = (4 + Math.random() * 3) + 's';
            
            const size = 3 + Math.random() * 6;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            
            particlesContainer.appendChild(particle);
        }

        // Burger Menu Toggle
        const burgerMenu = document.getElementById('burgerMenu');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');

        burgerMenu.addEventListener('click', () => {
            burgerMenu.classList.toggle('active');
            sidebar.classList.toggle('collapsed');
            mainContent.classList.toggle('expanded');
        });

        // Menu navigation
        document.getElementById('menu-dashboard').addEventListener('click', (e) => {
            e.preventDefault();
            showSection('dashboard');
        });

        document.getElementById('menu-profile').addEventListener('click', (e) => {
            e.preventDefault();
            showSection('profile');
        });

        document.getElementById('menu-submitted').addEventListener('click', (e) => {
            e.preventDefault();
            showSection('submitted');
            loadJobOrders();
        });

        document.getElementById('menu-diagnostics').addEventListener('click', (e) => {
            e.preventDefault();
            showSection('diagnostics');
            loadDiagnostics();
        });

        document.getElementById('menu-rto').addEventListener('click', (e) => {
            e.preventDefault();
            window.location.href = '/rto-list';
        });

        function loadJobOrders() {
            fetch('/api/job-orders')
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        const jobOrders = result.jobOrders || [];
                        const tbody = document.getElementById('jobOrdersBody');
                        
                        if (jobOrders.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="7" class="empty-message">No submitted job orders yet.</td></tr>';
                            return;
                        }

                        tbody.innerHTML = '';
                        jobOrders.forEach((order) => {
                            const row = document.createElement('tr');
                            row.style.cursor = 'pointer';
                            const problemsText = Array.isArray(order.selectedProblems) 
                                ? order.selectedProblems.slice(0, 2).join(', ') + (order.selectedProblems.length > 2 ? '...' : '')
                                : order.selectedProblems;
                            
// Use submittedDate directly from the backend
                            const submittedDate = order.submittedDate || 'N/A';

                            row.innerHTML = `
                                <td>${order.id}</td>
                                <td>${order.customerName}</td>
                                <td>${order.deviceType}</td>
                                <td>${order.brandModel}</td>
                                <td title="${Array.isArray(order.selectedProblems) ? order.selectedProblems.join(', ') : order.selectedProblems}">${problemsText}</td>
                                <td>${submittedDate}</td>
                                <td><span class="status-badge" data-status="${order.status}">${order.status}</span></td>
                            `;
                            row.addEventListener('click', () => openTechnicianJobOrderModal(order));
                            tbody.appendChild(row);
                        });
                    } else {
                        console.error('Error loading job orders:', result.message);
                        const tbody = document.getElementById('jobOrdersBody');
                        tbody.innerHTML = '<tr><td colspan="7" class="empty-message">Error loading job orders</td></tr>';
                    }
                })
                .catch(error => {
                    console.error('Error fetching job orders:', error);
                    const tbody = document.getElementById('jobOrdersBody');
                    tbody.innerHTML = '<tr><td colspan="7" class="empty-message">Error loading job orders</td></tr>';
                });
        }

        function loadDiagnostics() {
            // First, fetch all job orders to verify which ones exist
            fetch('/api/job-orders')
                .then(jobOrderResponse => jobOrderResponse.json())
                .then(jobOrderResult => {
                    const existingJobOrderIds = jobOrderResult.jobOrders ? jobOrderResult.jobOrders.map(jo => jo.id) : [];
                    
                    // Now fetch diagnostics and filter by existing job orders
                    return fetch('/api/diagnostic')
                        .then(response => {
                            console.log('Diagnostics response status:', response.status);
                            if (!response.ok) {
                                throw new Error(`HTTP error! status: ${response.status}`);
                            }
                            return response.json();
                        })
                        .then(result => {
                            console.log('Diagnostics result:', result);
                            if (result.success) {
                                const allDiagnostics = result.diagnostics || [];
                                // Filter diagnostics to only show those with existing job orders
                                const diagnostics = allDiagnostics.filter(diag => existingJobOrderIds.includes(diag.jobOrderId) && diag.status !== 'RTO');
                                const tbody = document.getElementById('diagnosticsBody');
                                
                                if (diagnostics.length === 0) {
                                    tbody.innerHTML = '<tr><td colspan="8" class="empty-message">No diagnostics created yet</td></tr>';
                                    return;
                                }
                                
                                tbody.innerHTML = '';
                                diagnostics.forEach((diag) => {
                            const row = document.createElement('tr');
                            row.style.cursor = 'pointer';
                            
                            const submittedDate = diag.createdAt 
                                ? new Date(diag.createdAt).toLocaleDateString('en-PH')
                                : 'N/A';

                            row.innerHTML = `
                                <td><strong style="color: #23a6d5;">${diag.diagnosticId}</strong></td>
                                <td>${diag.jobOrderId}</td>
                                <td>${diag.customerName}</td>
                                <td>${Array.isArray(diag.problems) ? diag.problems.join(', ') : diag.problems || 'N/A'}</td>
                                <td>${diag.deviceType}</td>
                                <td><span class="status-badge status-glow" data-status="${diag.status}">${diag.status}</span></td>
                                <td>${submittedDate}</td>
                                <td>
                                    <button onclick="viewDiagnosticDetail('${diag.id}'); event.stopPropagation();" style="background: rgba(35, 166, 213, 0.2); color: #23a6d5; border: 1px solid rgba(35, 166, 213, 0.3); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85em; transition: all 0.3s;">View</button>
                                    <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px;">
                                        <button onclick="editDiagnosticDetail('${diag.id}'); event.stopPropagation();" class="btn-glow" style="background: rgba(34, 197, 94, 0.2); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85em; transition: all 0.3s; ${diag.status !== 'Pending' ? 'display:none;' : ''}">Edit</button>
                                        <button onclick="deleteDiagnosticDetail('${diag.id}'); event.stopPropagation();" class="btn-glow" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85em; transition: all 0.3s; ${diag.status !== 'Pending' ? 'display:none;' : ''}">Delete</button>
                                    </div>
                                </td>
                            `;
                            tbody.appendChild(row);
                        });
                    } else {
                        console.error('Error loading diagnostics:', result.message);
                        const tbody = document.getElementById('diagnosticsBody');
                        tbody.innerHTML = '<tr><td colspan="8" class="empty-message">Error: ' + (result.message || 'Failed to load diagnostics') + '</td></tr>';
                    }
                });
                })
                .catch(error => {
                    console.error('Error fetching diagnostics:', error);
                    const tbody = document.getElementById('diagnosticsBody');
                    tbody.innerHTML = '<tr><td colspan="8" class="empty-message">Error: ' + error.message + '</td></tr>';
                });
        }

        // Diagnostic Modal Functions
        let currentDiagnostic = null;

        function viewDiagnosticDetail(diagnosticId) {
            fetch(`/api/diagnostic/${diagnosticId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        currentDiagnostic = data.diagnostic;
                        displayDiagnosticModal(data.diagnostic);
                    }
                })
                .catch(err => console.error('Error loading diagnostic:', err));
        }

        function displayDiagnosticModal(diag) {
            const detailsHtml = `
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Diagnostic ID</div>
                        <div style="color: #23a6d5; font-weight: 600;">${diag.diagnosticId}</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Job Order ID</div>
                        <div style="color: white; font-weight: 600;">${diag.jobOrderId}</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Customer</div>
                        <div style="color: white; font-weight: 600;">${diag.customerName}</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Device Type</div>
                        <div style="color: white; font-weight: 600;">${diag.deviceType}</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Est. Cost</div>
                        <div style="color: #22c55e; font-weight: 600;">₱${diag.estimatedCost.toFixed(2)}</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px;">
                        <div style="color: rgba(255,255,255,0.6); font-size: 0.85em; text-transform: uppercase;">Est. Complete</div>
                        <div style="color: white; font-weight: 600;">${new Date(diag.estimatedDurationDate).toLocaleDateString('en-PH')}</div>
                    </div>
                </div>
            `;
            
            // Images Gallery
            let imagesHtml = '';
            if (diag.images && diag.images.length > 0) {
                imagesHtml = `
                    <div style="margin-bottom: 20px;">
                        <div style="color: #23a6d5; font-size: 1em; font-weight: 600; margin-bottom: 12px; text-transform: uppercase;">📸 Images</div>
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px;">
                            ${diag.images.map((img, idx) => `
                                <div style="position: relative; border-radius: 8px; overflow: hidden; border: 2px solid rgba(35, 166, 213, 0.3); aspect-ratio: 1; cursor: pointer; transition: all 0.3s;" onclick="expandDiagImage(${idx})" title="Click to view full size">
                                    <img src="${img.data}" alt="Diagnostic Image ${idx + 1}" style="width: 100%; height: 100%; object-fit: cover;">
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
            
            // Video
            let videoHtml = '';
            if (diag.videoData && diag.videoData.data) {
                videoHtml = `
                    <div style="margin-bottom: 20px;">
                        <div style="color: #23a6d5; font-size: 1em; font-weight: 600; margin-bottom: 12px; text-transform: uppercase;">🎬 Video</div>
                        <video width="100%" height="250" controls style="border-radius: 10px; border: 2px solid rgba(35, 166, 213, 0.3);">
                            <source src="${diag.videoData.data}" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                `;
            }
            
            // Materials
            const materialsHtml = `
                <div style="margin-bottom: 15px;">
                    <div style="color: #23a6d5; font-size: 1em; font-weight: 600; margin-bottom: 12px; text-transform: uppercase;">🔧 Materials</div>
                    <table style="width: 100%; border-collapse: collapse; background: rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden;">
                        <thead>
                            <tr style="background: rgba(35, 166, 213, 0.2);">
                                <th style="padding: 10px; text-align: left; color: #23a6d5; font-size: 0.85em;">Material</th>
                                <th style="padding: 10px; text-align: center; color: #23a6d5; font-size: 0.85em;">Qty</th>
                                <th style="padding: 10px; text-align: right; color: #23a6d5; font-size: 0.85em;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${diag.materials && diag.materials.length > 0 ? diag.materials.map(m => `
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                                    <td style="padding: 10px; color: white;">${m.name}</td>
                                    <td style="padding: 10px; text-align: center; color: white;">${m.quantity}</td>
                                    <td style="padding: 10px; text-align: right;">${m.outOfStock ? '<span style="background: rgba(239, 68, 68, 0.2); color: #ef4444; padding: 4px 8px; border-radius: 4px; font-size: 0.8em;">Out of Stock</span>' : '<span style="background: rgba(34, 197, 94, 0.2); color: #22c55e; padding: 4px 8px; border-radius: 4px; font-size: 0.8em;">In Stock</span>'}</td>
                                </tr>
                            `).join('') : '<tr><td colspan="3" style="padding: 15px; text-align: center; color: rgba(255,255,255,0.5);">No materials</td></tr>'}
                        </tbody>
                    </table>
                </div>
            `;
            
            // Notes
            const notesHtml = diag.notes ? `
                <div style="margin-bottom: 15px;">
                    <div style="color: #23a6d5; font-size: 1em; font-weight: 600; margin-bottom: 12px; text-transform: uppercase;">📝 Notes</div>
                    <div style="background: rgba(255,255,255,0.05); padding: 12px; border-radius: 8px; color: white;">${diag.notes}</div>
                </div>
            ` : '';
            
            document.getElementById('diagnosticModalBody').innerHTML = detailsHtml + imagesHtml + videoHtml + materialsHtml + notesHtml;
            
            // Show/hide action buttons
            const editBtn = document.getElementById('diagEditBtn');
            const deleteBtn = document.getElementById('diagDeleteBtn');
            if (diag.status === 'Pending') {
                editBtn.style.display = 'inline-block';
                deleteBtn.style.display = 'inline-block';
            } else {
                editBtn.style.display = 'none';
                deleteBtn.style.display = 'none';
            }
            
            document.getElementById('diagnosticModal').classList.add('active');
        }
        
        function expandDiagImage(index) {
            if (currentDiagnostic && currentDiagnostic.images && currentDiagnostic.images[index]) {
                const img = currentDiagnostic.images[index];
                const modal = document.createElement('div');
                modal.className = 'image-expand-modal';
                modal.style.cssText = 'position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 3000; display: flex; align-items: center; justify-content: center;';
                modal.innerHTML = `
                    <span onclick="this.parentElement.remove();" style="position: absolute; top: 20px; right: 40px; font-size: 40px; font-weight: bold; cursor: pointer; color: white; z-index: 3001;">&times;</span>
                    <img src="${img.data}" style="max-width: 90%; max-height: 90%; border-radius: 10px; box-shadow: 0 0 50px rgba(102, 126, 234, 0.8);">
                `;
                document.body.appendChild(modal);
            }
        }

        function closeDiagnosticModal() {
            document.getElementById('diagnosticModal').classList.remove('active');
            currentDiagnostic = null;
        }

        function editDiagnosticDetail(diagnosticId) {
            viewDiagnosticDetail(diagnosticId);
            // Open edit modal after viewing
            setTimeout(() => {
                openEditModal();
            }, 500);
        }

        function openEditModal() {
            if (!currentDiagnostic || currentDiagnostic.status !== 'Pending') return;
            
            // Populate edit form
            document.getElementById('editDiagId').value = currentDiagnostic.id;
            document.getElementById('editDiagCost').value = currentDiagnostic.estimatedCost;
            document.getElementById('editDiagDate').value = currentDiagnostic.estimatedDurationDate ? currentDiagnostic.estimatedDurationDate.split('T')[0] : '';
            document.getElementById('editDiagNotes').value = currentDiagnostic.notes || '';
            
            // Populate materials
            const matContainer = document.getElementById('editDiagMaterials');
            if (currentDiagnostic.materials && currentDiagnostic.materials.length > 0) {
                matContainer.innerHTML = currentDiagnostic.materials.map(m => `
                    <div style="display: grid; grid-template-columns: 1fr 80px auto; gap: 8px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 6px; margin-bottom: 8px;">
                        <input type="text" value="${m.name}" class="edit-mat-name" style="padding: 8px; border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; background: rgba(255,255,255,0.1); color: white;">
                        <input type="number" value="${m.quantity}" class="edit-mat-qty" min="1" style="padding: 8px; border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; background: rgba(255,255,255,0.1); color: white;">
                        <label style="display: flex; align-items: center; gap: 5px; color: rgba(255,255,255,0.7); cursor: pointer;">
                            <input type="checkbox" class="edit-mat-out" ${m.outOfStock ? 'checked' : ''}> Out
                        </label>
                    </div>
                `).join('');
            } else {
                matContainer.innerHTML = '<p style="color: rgba(255,255,255,0.5);">No materials</p>';
            }
            
            closeDiagnosticModal();
            document.getElementById('editDiagnosticModal').classList.add('active');
        }

        function addEditMaterial() {
            const container = document.getElementById('editDiagMaterials');
            const div = document.createElement('div');
            div.style.cssText = 'display: grid; grid-template-columns: 1fr 80px auto; gap: 8px; background: rgba(255,255,255,0.05); padding: 10px; border-radius: 6px; margin-bottom: 8px;';
            div.innerHTML = `
                <input type="text" placeholder="Material Name" class="edit-mat-name" style="padding: 8px; border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; background: rgba(255,255,255,0.1); color: white;">
                <input type="number" value="1" class="edit-mat-qty" min="1" style="padding: 8px; border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; background: rgba(255,255,255,0.1); color: white;">
                <label style="display: flex; align-items: center; gap: 5px; color: rgba(255,255,255,0.7); cursor: pointer;">
                    <input type="checkbox" class="edit-mat-out"> Out
                </label>
            `;
            container.appendChild(div);
        }

        function closeEditModal() {
            document.getElementById('editDiagnosticModal').classList.remove('active');
        }

        function saveDiagnosticEdit(e) {
            e.preventDefault();
            const diagId = document.getElementById('editDiagId').value;
            const cost = parseFloat(document.getElementById('editDiagCost').value);
            const date = document.getElementById('editDiagDate').value;
            const notes = document.getElementById('editDiagNotes').value;
            
            const materials = [];
            document.querySelectorAll('#editDiagMaterials > div').forEach(div => {
                const name = div.querySelector('.edit-mat-name').value.trim();
                if (name) {
                    materials.push({
                        name: name,
                        quantity: parseInt(div.querySelector('.edit-mat-qty').value) || 1,
                        outOfStock: div.querySelector('.edit-mat-out').checked
                    });
                }
            });
            
            fetch(`/api/diagnostic/${diagId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    estimatedCost: cost,
                    estimatedDurationDate: date,
                    notes: notes,
                    materials: materials
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification('Diagnostic updated successfully!', 'success');
                    closeEditModal();
                    loadDiagnostics();
                } else {
                    showNotification(data.message || 'Error updating diagnostic', 'error');
                }
            })
            .catch(err => showNotification('Error: ' + err.message, 'error'));
        }

        function deleteDiagnosticDetail(diagnosticId) {
            console.log('Delete diagnostic called with ID:', diagnosticId);
            // Set currentDiagnostic with the ID directly so we can delete it
            currentDiagnostic = { id: diagnosticId };
            console.log('Current diagnostic set for delete:', currentDiagnostic);
            // Open delete modal directly
            document.getElementById('deleteDiagnosticModal').classList.add('active');
        }

        function openDeleteModal() {
            if (!currentDiagnostic) return;
            closeDiagnosticModal();
            document.getElementById('deleteDiagnosticModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteDiagnosticModal').classList.remove('active');
        }

        function confirmDelete() {
            if (!currentDiagnostic) {
                showNotification('No diagnostic selected', 'error');
                return;
            }
            console.log('Confirm delete called for diagnostic ID:', currentDiagnostic.id);
            console.log('Confirm delete called for diagnostic status:', currentDiagnostic.status);
            
            fetch(`/api/diagnostic/${currentDiagnostic.id}`, {
                method: 'DELETE'
            })
            .then(res => {
                console.log('Delete API response status:', res.status);
                return res.json();
            })
            .then(data => {
                console.log('Delete API response data:', data);
                if (data.success) {
                    showNotification('Diagnostic deleted successfully', 'success');
                    closeDeleteModal();
                    loadDiagnostics();
                } else {
                    showNotification(data.message || 'Error deleting diagnostic', 'error');
                }
            })
            .catch(err => {
                console.error('Delete error:', err);
                showNotification('Error: ' + err.message, 'error');
            });
        }

        function openCreateDiagnosticModal() {
            const modal = document.getElementById('createDiagnosticModal');
            modal.style.display = 'flex';
        }

        function closeCreateDiagnosticModal() {
            const modal = document.getElementById('createDiagnosticModal');
            modal.style.display = 'none';
            
            // Reset iframe src to reload the form fresh next time
            const iframe = document.getElementById('diagnosticFormIframe');
            if (iframe) {
                iframe.src = iframe.src;
            }
        }

        // Listen for messages from the diagnostic form iframe
        window.addEventListener('message', function(event) {
            if (event.data && event.data.type === 'diagnostic-created') {
                console.log('Diagnostic created:', event.data.diagnosticId);
                closeCreateDiagnosticModal();
                showNotification('Diagnostic created successfully!', 'success');
                loadDiagnostics();
            }
        });

        // Also listen for custom events from same origin
        window.addEventListener('diagnostic-created', function(e) {
            console.log('Diagnostic created via custom event:', e.detail);
            closeCreateDiagnosticModal();
            showNotification('Diagnostic created successfully!', 'success');
            loadDiagnostics();
        });

        function showNotification(message, type, targetModalId = null) {
            // Create glowing notification element
            const notification = document.createElement('div');
            notification.className = `modal-notification ${type}`;
            
            const icon = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ️';
            notification.innerHTML = `
                <span class="notification-icon">${icon}</span>
                <span class="notification-message">${message}</span>
                <span class="notification-close" onclick="this.parentElement.remove()">&times;</span>
            `;
            
            // Style for the notification
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                left: 50%;
                transform: translateX(-50%);
                z-index: 4000;
                padding: 15px 25px;
                border-radius: 12px;
                font-weight: 600;
                font-size: 15px;
                display: flex;
                align-items: center;
                gap: 12px;
                min-width: 300px;
                max-width: 500px;
                animation: notificationSlideIn 0.5s ease-out, notificationGlowPulse 2s ease-in-out infinite;
                backdrop-filter: blur(10px);
                border: 2px solid;
                box-shadow: 0 0 30px rgba(0,0,0,0.3);
            `;
            
            if (type === 'success') {
                notification.style.background = 'rgba(34, 197, 94, 0.2)';
                notification.style.color = '#22c55e';
                notification.style.borderColor = 'rgba(34, 197, 94, 0.6)';
                notification.style.boxShadow = '0 0 30px rgba(34, 197, 94, 0.5), 0 8px 25px rgba(0,0,0,0.3)';
            } else if (type === 'error') {
                notification.style.background = 'rgba(239, 68, 68, 0.2)';
                notification.style.color = '#ef4444';
                notification.style.borderColor = 'rgba(239, 68, 68, 0.6)';
                notification.style.boxShadow = '0 0 30px rgba(239, 68, 68, 0.5), 0 8px 25px rgba(0,0,0,0.3)';
            } else {
                notification.style.background = 'rgba(59, 130, 246, 0.2)';
                notification.style.color = '#3b82f6';
                notification.style.borderColor = 'rgba(59, 130, 246, 0.6)';
                notification.style.boxShadow = '0 0 30px rgba(59, 130, 246, 0.5), 0 8px 25px rgba(0,0,0,0.3)';
            }
            
            // Style for icon
            notification.querySelector('.notification-icon').style.cssText = `
                font-size: 20px;
                font-weight: bold;
            `;
            
            // Style for message
            notification.querySelector('.notification-message').style.cssText = `
                flex: 1;
            `;
            
            // Style for close button
            notification.querySelector('.notification-close').style.cssText = `
                font-size: 20px;
                cursor: pointer;
                opacity: 0.7;
                transition: opacity 0.3s;
            `;
            notification.querySelector('.notification-close').onmouseover = function() {
                this.style.opacity = '1';
            };
            notification.querySelector('.notification-close').onmouseout = function() {
                this.style.opacity = '0.7';
            };
            
            document.body.appendChild(notification);
            
            // Auto remove after 4 seconds
            setTimeout(() => {
                notification.style.animation = 'notificationSlideOut 0.5s ease-in forwards';
                setTimeout(() => notification.remove(), 500);
            }, 4000);
        }


        function showSection(sectionId) {
            // Hide all sections
            const sections = document.querySelectorAll('.content-section');
            sections.forEach(section => section.classList.remove('active'));
            
            // Remove active class from all menu items
            const menuLinks = document.querySelectorAll('.menu-link');
            menuLinks.forEach(link => link.classList.remove('active'));
            
            // Show selected section
            document.getElementById(sectionId).classList.add('active');
            
            // Add active class to the clicked menu item
            if (sectionId === 'dashboard') {
                document.getElementById('menu-dashboard').classList.add('active');
            } else if (sectionId === 'profile') {
                document.getElementById('menu-profile').classList.add('active');
            } else if (sectionId === 'submitted') {
                document.getElementById('menu-submitted').classList.add('active');
            } else if (sectionId === 'diagnostics') {
                document.getElementById('menu-diagnostics').classList.add('active');
            }
        }

        // Job Order Modal Functions
        function openTechnicianJobOrderModal(order) {
            const problemsList = Array.isArray(order.selectedProblems)
                ? order.selectedProblems.map(p => `<li>${p}</li>`).join('')
                : `<li>${order.selectedProblems}</li>`;

            const createdDate = order.createdAt ? new Date(order.createdAt).toLocaleString() : 'N/A';

            const modalBody = document.getElementById('techJobOrderModalBody');
            modalBody.innerHTML = `
                <div class="job-detail-item">
                    <span class="job-detail-label">Job Order ID:</span>
                    <span class="job-detail-value">${order.id}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Customer Name:</span>
                    <span class="job-detail-value">${order.customerName}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Phone Number:</span>
                    <span class="job-detail-value">${order.customerNumber}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Address:</span>
                    <span class="job-detail-value">${order.customerAddress}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Device Type:</span>
                    <span class="job-detail-value">${order.deviceType}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Brand & Model:</span>
                    <span class="job-detail-value">${order.brandModel}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Generation:</span>
                    <span class="job-detail-value">${order.generation || 'N/A'}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Problems:</span>
                </div>
                <div class="problems-list">
                    <ul>
                        ${problemsList}
                    </ul>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Submitted Date:</span>
                    <span class="job-detail-value">${createdDate}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Current Status:</span>
                    <span class="job-detail-value">${order.status}</span>
                </div>
                ${order.diagnosticId ? `
                <div class="job-detail-item">
                    <span class="job-detail-label">Diagnostic ID:</span>
                    <span class="job-detail-value" style="color: #23a6d5; font-weight: 700;">${order.diagnosticId}</span>
                </div>
                <div class="job-detail-item">
                    <span class="job-detail-label">Last Diagnostic Date:</span>
                    <span class="job-detail-value">${order.lastDiagnosticDate || 'N/A'}</span>
                </div>
                ` : ''}
                ${order.diagnosticHistory && order.diagnosticHistory.length > 0 ? `
                <div class="job-detail-item">
                    <span class="job-detail-label">Diagnostic History:</span>
                </div>
                <div style="padding: 15px; background: rgba(255, 255, 255, 0.05); border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1); margin: 15px 0;">
                    <table style="width: 100%; color: white; font-size: 0.9em;">
                        <thead>
                            <tr style="border-bottom: 1px solid rgba(35, 166, 213, 0.3);">
                                <th style="text-align: left; padding: 8px; color: #23a6d5;">Diagnostic ID</th>
                                <th style="text-align: left; padding: 8px; color: #23a6d5;">Submitted Date</th>
                                <th style="text-align: left; padding: 8px; color: #23a6d5;">Status</th>
                                <th style="text-align: right; padding: 8px; color: #23a6d5;">Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${order.diagnosticHistory.map(d => `
                                <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.08);">
                                    <td style="padding: 8px;">${d.diagnosticId}</td>
                                    <td style="padding: 8px;">${d.submittedDate}</td>
                                    <td style="padding: 8px;"><span style="color: #ff9600; font-weight: 600;">${d.status}</span></td>
                                    <td style="text-align: right; padding: 8px;">₱${d.estimatedCost.toFixed(2)}</td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                ` : ''}
                ${order.signature ? `
                <div class="job-detail-item">
                    <span class="job-detail-label">Customer Digital Signature:</span>
                </div>
                <div style="padding: 15px; background: rgba(255, 255, 255, 0.05); border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1); margin: 15px 0;">
                    <img src="${order.signature}" alt="Customer Signature" style="max-width: 100%; height: auto; border-radius: 8px;">
                </div>
                ` : `
                <div class="job-detail-item">
                    <span class="job-detail-label">Customer Digital Signature:</span>
                    <span class="job-detail-value" style="color: rgba(255, 193, 7, 0.8);">No signature on file</span>
                </div>
                `}
            `;

            document.getElementById('techJobOrderModal').classList.add('active');
        }

        function closeTechnicianJobOrderModal() {
            document.getElementById('techJobOrderModal').classList.remove('active');
        }

        // Close modal when clicking outside
        document.addEventListener('click', (e) => {
            const modal = document.getElementById('techJobOrderModal');
            if (e.target.id === 'techJobOrderModal') {
                closeTechnicianJobOrderModal();
            }
        });
    </script>

    <!-- Job Order Modal -->
    <div id="techJobOrderModal" class="job-order-modal">
        <div class="job-order-modal-content">
            <div class="job-order-modal-header">
                <div>
                    <h2>Job Order Details</h2>
                    <p style="font-size: 0.9em; color: rgba(255, 255, 255, 0.6); margin-top: 5px;">📖 View Your Submitted Job Order</p>
                </div>
                <button class="job-order-modal-close" onclick="closeTechnicianJobOrderModal()">&times;</button>
            </div>
            <div class="job-order-modal-body">
                <div id="techJobOrderModalBody"></div>
            </div>
            <div class="job-order-modal-footer">
                <button onclick="closeTechnicianJobOrderModal()" class="form-btn modal-btn-back" style="width: 100%; text-align: center;">Close</button>
            </div>
        </div>
    </div>

    <style>
        .job-order-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeInModal 0.3s ease-in-out;
        }

        .job-order-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .job-order-modal-content {
            background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
            border: 1px solid rgba(35, 166, 213, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(35, 166, 213, 0.2);
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideUpModal 0.3s ease-in-out;
        }

        .job-order-modal-header {
            padding: 25px;
            border-bottom: 1px solid rgba(35, 166, 213, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .job-order-modal-header div {
            flex: 1;
        }

        .job-order-modal-header h2 {
            margin: 0;
            font-size: 1.5em;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .job-order-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .job-order-modal-close:hover {
            opacity: 1;
        }

        .job-order-modal-body {
            padding: 25px;
            color: white;
        }

        .job-detail-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 12px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .job-detail-label {
            font-weight: 600;
            color: #23a6d5;
            min-width: 150px;
        }

        .job-detail-value {
            text-align: right;
            flex: 1;
            color: #e2e8f0;
            word-break: break-word;
        }

        .problems-list {
            margin-top: 10px;
            padding-left: 150px;
        }

        .problems-list ul {
            margin: 0;
            padding-left: 20px;
            list-style-type: disc;
            color: #e2e8f0;
        }

        .problems-list li {
            padding: 5px 0;
        }

        .job-order-modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(35, 166, 213, 0.2);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .job-order-modal-footer .form-btn {
            padding: 12px 24px;
            font-size: 0.95em;
        }

        .form-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f702a8 100%);
            background-size: 200% 200%;
            color: white;
            padding: 16px 40px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 700;
            width: 100%;
            transition: all 0.4s;
            text-transform: uppercase;
            letter-spacing: 2px;
            box-shadow: 0 0 25px rgba(102, 126, 234, 0.5), 0 8px 25px rgba(0, 0, 0, 0.3);
