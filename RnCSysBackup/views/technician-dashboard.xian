        .modal-btn-back:hover {
            background: rgba(255, 255, 255, 0.25) !important;
            border-color: rgba(255, 255, 255, 0.5) !important;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2) !important;
            transform: translateY(-2px);
        }

        @keyframes btnGradientMove {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @keyframes fadeInModal {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        @keyframes slideUpModal {
            from {
                transform: translateY(50px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Diagnostic Modal Styles */
        .diagnostic-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeInModal 0.3s ease-in-out;
        }

        .diagnostic-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .diagnostic-modal-content {
            background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
            border: 1px solid rgba(35, 166, 213, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(35, 166, 213, 0.2);
            max-width: 700px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideUpModal 0.3s ease-in-out;
        }

        .diagnostic-modal-header {
            padding: 25px;
            border-bottom: 1px solid rgba(35, 166, 213, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .diagnostic-modal-header h2 {
            margin: 0;
            font-size: 1.5em;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .diagnostic-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .diagnostic-modal-close:hover {
            opacity: 1;
        }

        .diagnostic-modal-body {
            padding: 25px;
            color: white;
        }

        .diagnostic-modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(35, 166, 213, 0.2);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        /* Edit Diagnostic Modal Styles */
        .edit-diagnostic-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeInModal 0.3s ease-in-out;
        }

        .edit-diagnostic-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .edit-diagnostic-modal-content {
            background: linear-gradient(135deg, #1a202c 0%, #2d3748 100%);
            border: 1px solid rgba(34, 197, 94, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(34, 197, 94, 0.2);
            max-width: 700px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideUpModal 0.3s ease-in-out;
        }

        .edit-diagnostic-modal-header {
            padding: 25px;
            border-bottom: 1px solid rgba(34, 197, 94, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .edit-diagnostic-modal-header h2 {
            margin: 0;
            font-size: 1.5em;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .edit-diagnostic-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .edit-diagnostic-modal-close:hover {
            opacity: 1;
        }

        .edit-diagnostic-modal-body {
            padding: 25px;
            color: white;
        }

        .edit-diagnostic-modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(34, 197, 94, 0.2);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        /* Delete Diagnostic Modal Styles */
        .delete-diagnostic-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeInModal 0.3s ease-in-out;
        }

        .delete-diagnostic-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .delete-diagnostic-modal-content {
            background: linear-gradient(135deg, #2d1b1b 0%, #3d2b2b 100%);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(239, 68, 68, 0.2);
            max-width: 450px;
            width: 90%;
            animation: slideUpModal 0.3s ease-in-out;
            text-align: center;
        }

        .delete-diagnostic-modal-header {
            padding: 25px;
            border-bottom: 1px solid rgba(239, 68, 68, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .delete-diagnostic-modal-header h2 {
            margin: 0;
            font-size: 1.5em;
            color: #ef4444;
        }

        .delete-diagnostic-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .delete-diagnostic-modal-close:hover {
            opacity: 1;
        }

        .delete-diagnostic-modal-body {
            padding: 25px;
            color: white;
        }

        .delete-diagnostic-modal-footer {
            padding: 20px 25px;
            border-top: 1px solid rgba(239, 68, 68, 0.2);
            display: flex;
            justify-content: center;
            gap: 15px;
        }

        /* Create Diagnostic Modal Styles */
        .create-diagnostic-modal {
            position: fixed;
            z-index: 2500;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .create-diagnostic-modal-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            animation: fadeInmodal 0.3s ease-in-out;
        }

        .create-diagnostic-modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 95%;
            max-width: 1000px;
            height: 95vh;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.3);
            display: flex;
            flex-direction: column;
            animation: slideUpModal 0.3s ease-in-out;
            z-index: 2501;
        }

        .create-diagnostic-modal-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(102, 126, 234, 0.1);
            border-radius: 15px 15px 0 0;
        }

        .create-diagnostic-modal-header h2 {
            margin: 0;
            font-size: 1.4em;
            color: white;
            text-shadow: 0 0 15px rgba(102, 126, 234, 0.4);
        }

        .create-diagnostic-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .create-diagnostic-modal-close:hover {
            opacity: 1;
        }

        .create-diagnostic-modal-body {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        #diagnosticFormIframe {
            display: block !important;
            height: 100% !important;
        }
    </style>

    <!-- View Diagnostic Modal -->
    <div id="diagnosticModal" class="diagnostic-modal">
        <div class="diagnostic-modal-content">
            <div class="diagnostic-modal-header">
                <div>
                    <h2>Diagnostic Details</h2>
                    <p style="font-size: 0.9em; color: rgba(255, 255, 255, 0.6); margin-top: 5px;">🔍 View Diagnostic Information</p>
                </div>
                <button class="diagnostic-modal-close" onclick="closeDiagnosticModal()">&times;</button>
            </div>
            <div class="diagnostic-modal-body" id="diagnosticModalBody">
            </div>
            <div class="diagnostic-modal-footer">
                <button id="diagEditBtn" onclick="openEditModal()" class="form-btn" style="background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); padding: 10px 20px; font-size: 0.9em;">Edit</button>
                <button id="diagDeleteBtn" onclick="openDeleteModal()" class="form-btn" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); padding: 10px 20px; font-size: 0.9em;">Delete</button>
                <button onclick="closeDiagnosticModal()" class="form-btn modal-btn-back" style="width: auto;">Close</button>
            </div>
        </div>
    </div>

    <!-- Edit Diagnostic Modal -->
    <div id="editDiagnosticModal" class="edit-diagnostic-modal">
        <div class="edit-diagnostic-modal-content">
            <div class="edit-diagnostic-modal-header">
                <div>
                    <h2>Edit Diagnostic</h2>
                    <p style="font-size: 0.9em; color: rgba(255, 255, 255, 0.6); margin-top: 5px;">✏️ Update Diagnostic Information</p>
                </div>
                <button class="edit-diagnostic-modal-close" onclick="closeEditModal()">&times;</button>
            </div>
            <form class="edit-diagnostic-modal-body" onsubmit="saveDiagnosticEdit(event)">
                <input type="hidden" id="editDiagId">
                
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px;">Estimated Cost (₱)</label>
                    <input type="number" id="editDiagCost" step="0.01" required style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.1); color: white; font-size: 1em;">
                </div>
                
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px;">Estimated Completion Date</label>
                    <input type="date" id="editDiagDate" required style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.1); color: white; font-size: 1em;">
                </div>
                
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px;">Materials</label>
                    <div id="editDiagMaterials" style="max-height: 150px; overflow-y: auto; margin-bottom: 10px;">
                    </div>
                    <button type="button" onclick="addEditMaterial()" style="background: rgba(255,255,255,0.1); border: 1px dashed rgba(255,255,255,0.3); color: white; padding: 8px 15px; border-radius: 6px; cursor: pointer;">+ Add Material</button>
                </div>
                
                <div style="margin-bottom: 15px;">
                    <label style="display: block; color: rgba(255,255,255,0.7); margin-bottom: 8px;">Notes</label>
                    <textarea id="editDiagNotes" rows="3" style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.1); color: white; font-size: 1em; resize: vertical;"></textarea>
                </div>
                
                <div class="edit-diagnostic-modal-footer" style="padding: 0; border: none; margin-top: 20px;">
                    <button type="button" onclick="closeEditModal()" class="form-btn modal-btn-back" style="width: auto;">Cancel</button>
                    <button type="submit" class="form-btn" style="width: auto;">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Diagnostic Modal -->
    <div id="deleteDiagnosticModal" class="delete-diagnostic-modal">
        <div class="delete-diagnostic-modal-content">
            <div class="delete-diagnostic-modal-header">
                <h2>Delete Diagnostic</h2>
                <button class="delete-diagnostic-modal-close" onclick="closeDeleteModal()">&times;</button>
            </div>
            <div class="delete-diagnostic-modal-body">
                <div style="font-size: 60px; margin-bottom: 20px;">⚠️</div>
                <p style="font-size: 1.1em; margin-bottom: 10px;">Are you sure you want to delete this diagnostic?</p>
                <p style="font-size: 0.9em; color: rgba(255,255,255,0.6);">This action cannot be undone.</p>
            </div>
            <div class="delete-diagnostic-modal-footer">
                <button onclick="closeDeleteModal()" class="form-btn modal-btn-back">Cancel</button>
                <button onclick="confirmDelete()" class="form-btn" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">Delete</button>
            </div>
        </div>
    </div>

    <!-- Create Diagnostic Modal -->
    <div id="createDiagnosticModal" class="create-diagnostic-modal" style="display: none; align-items: center; justify-content: center;">
        <div class="create-diagnostic-modal-overlay" onclick="closeCreateDiagnosticModal()"></div>
        <div class="create-diagnostic-modal-content">
            <div class="create-diagnostic-modal-header">
                <h2>📋 Create Diagnostic Form</h2>
                <button class="create-diagnostic-modal-close" onclick="closeCreateDiagnosticModal()">&times;</button>
            </div>
            <div class="create-diagnostic-modal-body">
                <iframe id="diagnosticFormIframe" src="/diagnostic" style="width: 100%; height: 100%; border: none; border-radius: 10px;"></iframe>
            </div>
        </div>
    </div>
</body>
</html>
