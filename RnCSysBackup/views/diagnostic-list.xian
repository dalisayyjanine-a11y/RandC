<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Diagnostics - RNC System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .bg-gradient {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab, #f702a8, #0af);
            background-size: 400% 400%;
            animation: gradientBG 8s ease infinite;
            opacity: 0.25;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(50px);
            animation: orbFloat 10s ease-in-out infinite;
        }

        .glow-orb-1 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(102, 126, 234, 0.5) 0%, transparent 70%);
            top: -50px;
            left: -50px;
        }

        .glow-orb-2 {
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(118, 75, 162, 0.5) 0%, transparent 70%);
            bottom: -50px;
            right: -50px;
            animation-delay: -5s;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(20px, -20px) scale(1.1); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .particle {
            position: absolute;
            width: 5px;
            height: 5px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 50%;
            animation: float 5s ease-in-out infinite;
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.6);
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
            50% { transform: translateY(-80px) rotate(180deg); opacity: 1; }
        }

        .main-content {
            flex: 1;
            padding: 25px;
            position: relative;
            z-index: 1;
            overflow-y: auto;
            height: 100vh;
        }

        .header {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            padding: 20px 25px;
            border-radius: 15px;
            margin-bottom: 25px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.15);
            animation: fadeInDown 0.6s ease-out;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header h1 {
            color: white;
            font-size: 1.8em;
            text-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
        }

        .btn-create {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(102, 126, 234, 0.6);
        }

        .diagnostics-container {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 30px;
            animation: fadeInUp 0.6s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .diagnostics-table {
            width: 100%;
            border-collapse: collapse;
            color: white;
        }

        .diagnostics-table thead {
            border-bottom: 2px solid rgba(35, 166, 213, 0.3);
        }

        .diagnostics-table th {
            padding: 18px;
            text-align: left;
            color: #23a6d5;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.9em;
            letter-spacing: 1px;
        }

        .diagnostics-table tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
            cursor: pointer;
        }

        .diagnostics-table tbody tr:hover {
            background: rgba(35, 166, 213, 0.15);
            box-shadow: inset 0 0 15px rgba(35, 166, 213, 0.1);
        }

        .diagnostics-table td {
            padding: 18px;
            vertical-align: middle;
        }

        .status-badge {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .status-pending {
            background: rgba(59, 130, 246, 0.2);
            color: #3b82f6;
            border: 1px solid rgba(59, 130, 246, 0.4);
        }

        .status-in-progress {
            background: rgba(249, 115, 22, 0.2);
            color: #f97316;
            border: 1px solid rgba(249, 115, 22, 0.4);
        }

        .status-completed {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.4);
        }

        .status-rejected {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.4);
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-view,
        .btn-edit,
        .btn-delete,
        .btn-rto {
            padding: 8px 14px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85em;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-view {
            background: rgba(35, 166, 213, 0.2);
            color: #23a6d5;
            border: 1px solid rgba(35, 166, 213, 0.3);
        }

        .btn-view:hover {
            background: rgba(35, 166, 213, 0.4);
            box-shadow: 0 0 15px rgba(35, 166, 213, 0.3);
        }

        .btn-edit {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.3);
        }

        .btn-edit:hover {
            background: rgba(34, 197, 94, 0.4);
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.4);
        }

        .btn-rto {
            background: rgba(249, 115, 22, 0.2);
            color: #f97316;
            border: 1px solid rgba(249, 115, 22, 0.3);
        }

        .btn-rto:hover {
            background: rgba(249, 115, 22, 0.4);
            box-shadow: 0 0 15px rgba(249, 115, 22, 0.3);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.6);
        }

        .empty-state h2 {
            color: rgba(255, 255, 255, 0.8);
            margin-bottom: 10px;
            font-size: 1.5em;
        }

        .empty-state p {
            margin-bottom: 20px;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            animation: fadeInModal 0.3s ease-out;
        }

        @keyframes fadeInModal {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.95) 0%, rgba(47, 43, 99, 0.95) 100%);
            margin: auto;
            padding: 40px;
            border: 2px solid rgba(35, 166, 213, 0.3);
            width: 90%;
            max-width: 800px;
            border-radius: 15px;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            top: 50%;
            transform: translateY(-50%);
            animation: slideInModal 0.4s ease-out;
            color: white;
        }

        @keyframes slideInModal {
            from {
                transform: translateY(-50%) scale(0.95);
                opacity: 0;
            }
            to {
                transform: translateY(-50%) scale(1);
                opacity: 1;
            }
        }

        .modal-title {
            font-size: 1.8em;
            margin-bottom: 20px;
            color: #23a6d5;
        }

        .diagnostic-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .detail-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .detail-label {
            color: rgba(255, 255, 255, 0.6);
            font-size: 0.9em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .detail-value {
            color: white;
            font-weight: 600;
            word-break: break-all;
        }

        .images-gallery {
            margin-bottom: 30px;
        }

        .gallery-title {
            color: #23a6d5;
            margin-bottom: 15px;
            font-size: 1.2em;
            font-weight: 600;
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
        }

        .gallery-item {
            position: relative;
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid rgba(35, 166, 213, 0.3);
            aspect-ratio: 1;
            cursor: pointer;
            transition: all 0.3s;
        }

        .gallery-item:hover {
            border-color: #23a6d5;
            box-shadow: 0 0 20px rgba(35, 166, 213, 0.4);
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .materials-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .materials-table th {
            background: rgba(35, 166, 213, 0.2);
            padding: 12px;
            text-align: left;
            color: #23a6d5;
            border-bottom: 2px solid rgba(35, 166, 213, 0.3);
        }

        .materials-table td {
            padding: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .out-of-stock-badge {
            display: inline-block;
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.8em;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-close-modal {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            padding: 10px 25px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-close-modal:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        /* Edit Modal Styles */
        .edit-modal-content {
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.95) 0%, rgba(47, 43, 99, 0.95) 100%);
            margin: auto;
            padding: 35px;
            border: 2px solid rgba(34, 197, 94, 0.3);
            width: 90%;
            max-width: 700px;
            border-radius: 15px;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            top: 50%;
            transform: translateY(-50%);
            animation: slideInModal 0.4s ease-out;
            color: white;
        }

        .edit-modal-title {
            font-size: 1.6em;
            margin-bottom: 20px;
            color: #22c55e;
        }

        .edit-form-section {
            margin-bottom: 20px;
        }

        .edit-form-section-title {
            color: #23a6d5;
            font-size: 1.1em;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(35, 166, 213, 0.3);
            padding-bottom: 8px;
        }

        .edit-form-group {
            margin-bottom: 15px;
        }

        .edit-form-group label {
            display: block;
            margin-bottom: 6px;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 600;
            font-size: 0.85em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .edit-form-group input,
        .edit-form-group textarea,
        .edit-form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            font-size: 0.95em;
            transition: all 0.3s;
            background: rgba(255, 255, 255, 0.05);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .edit-form-group input:focus,
        .edit-form-group textarea:focus,
        .edit-form-group select:focus {
            outline: none;
            border-color: #22c55e;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.2);
            background: rgba(255, 255, 255, 0.1);
        }

        .edit-material-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 200px;
            overflow-y: auto;
        }

        .edit-material-item {
            display: grid;
            grid-template-columns: 1fr 100px auto;
            gap: 10px;
            background: rgba(255, 255, 255, 0.05);
            padding: 12px;
            border-radius: 8px;
            align-items: center;
        }

        .edit-material-item input[type="text"] {
            padding: 8px 12px;
            font-size: 0.9em;
        }

        .edit-material-item .checkbox-group {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .edit-material-item .checkbox-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .edit-material-item .checkbox-group label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.8em;
            margin: 0;
            text-transform: none;
        }

        .btn-remove-material {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.85em;
        }

        .btn-remove-material:hover {
            background: rgba(239, 68, 68, 0.4);
        }

        .btn-add-material {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.3);
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.85em;
            margin-top: 8px;
        }

        .btn-add-material:hover {
            background: rgba(34, 197, 94, 0.4);
        }

        .edit-images-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }

        .edit-image-preview-item {
            position: relative;
            width: 80px;
            height: 80px;
            border-radius: 6px;
            overflow: hidden;
            border: 2px solid rgba(35, 166, 213, 0.4);
        }

        .edit-image-preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .edit-image-preview-item .remove {
            position: absolute;
            top: 2px;
            right: 2px;
            width: 18px;
            height: 18px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            font-size: 12px;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .edit-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 20px;
        }

        .btn-save-edit {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: white;
            padding: 10px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-save-edit:hover {
            background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
            box-shadow: 0 0 15px rgba(34, 197, 94, 0.4);
        }

        /* Delete Modal Styles */
        .delete-modal-content {
            background: linear-gradient(135deg, rgba(80, 20, 20, 0.95) 0%, rgba(60, 20, 40, 0.95) 100%);
            margin: auto;
            padding: 35px;
            border: 2px solid rgba(239, 68, 68, 0.3);
            width: 90%;
            max-width: 450px;
            border-radius: 15px;
            position: relative;
            top: 50%;
            transform: translateY(-50%);
            animation: slideInModal 0.4s ease-out;
            color: white;
            text-align: center;
        }

        .delete-modal-title {
            font-size: 1.6em;
            margin-bottom: 15px;
            color: #ef4444;
        }

        .delete-modal-icon {
            font-size: 4em;
            margin-bottom: 15px;
        }

        .delete-modal-message {
            font-size: 1.1em;
            margin-bottom: 10px;
            color: rgba(255, 255, 255, 0.9);
        }

        .delete-modal-submessage {
            font-size: 0.9em;
            margin-bottom: 25px;
            color: rgba(255, 255, 255, 0.6);
        }

        .delete-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            padding-top: 15px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-confirm-delete {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-confirm-delete:hover {
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            box-shadow: 0 0 20px rgba(239, 68, 68, 0.5);
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 18px 28px;
            border-radius: 12px;
            font-weight: 600;
            z-index: 2500;
            animation: slideInNotification 0.5s ease-out;
            backdrop-filter: blur(10px);
            border: 2px solid;
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 400px;
        }

        .notification.success {
            background: rgba(34, 197, 94, 0.15);
            color: #22c55e;
            border-color: rgba(34, 197, 94, 0.5);
        }

        .notification.error {
            background: rgba(239, 68, 68, 0.15);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.5);
        }

        @media (max-width: 768px) {
            .diagnostic-details {
                grid-template-columns: 1fr;
            }

            .modal-content {
                width: 95%;
                padding: 20px;
            }

            .gallery-grid {
                grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            }

            .action-buttons {
                flex-direction: column;
            }
        }

        /* Create Diagnostic Modal Styles */
        .create-diagnostic-modal {
            display: none;
            position: fixed;
            z-index: 2500;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .create-diagnostic-modal.show {
            display: block;
        }

        .create-diagnostic-modal-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
            animation: fadeInOverlay 0.3s ease-out;
        }

        @keyframes fadeInOverlay {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .create-diagnostic-modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.8);
            width: 95%;
            max-width: 1000px;
            height: 95vh;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.3), 0 25px 50px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
            animation: popInModal 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            z-index: 2501;
            opacity: 0;
        }

        @keyframes popInModal {
            0% {
                opacity: 0;
                transform: translate(-50%, -50%) scale(0.5);
            }
            100% {
                opacity: 1;
                transform: translate(-50%, -50%) scale(1);
            }
        }

        .create-diagnostic-modal-header {
            padding: 20px 25px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(102, 126, 234, 0.1);
            border-radius: 15px 15px 0 0;
        }

        .create-diagnostic-modal-header h2 {
            margin: 0;
            font-size: 1.4em;
            color: white;
            text-shadow: 0 0 15px rgba(102, 126, 234, 0.4);
        }

        .create-diagnostic-modal-close {
            background: none;
            border: none;
            color: white;
            font-size: 2em;
            cursor: pointer;
            padding: 0;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .create-diagnostic-modal-close:hover {
            opacity: 1;
        }

        .create-diagnostic-modal-body {
            flex: 1;
            overflow-y: auto;
            padding: 0;
        }

        #diagnosticFormIframe {
            display: block !important;
            height: 100% !important;
        }

        /* RTO Modal Styles */
        .rto-modal {
            display: none;
            position: fixed;
            z-index: 2200;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .rto-modal.show {
            display: block;
        }

        .rto-modal-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .rto-modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 95%;
            max-width: 1000px;
            max-height: 90vh;
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.95) 0%, rgba(47, 43, 99, 0.95) 100%);
            border: 2px solid rgba(249, 115, 22, 0.3);
            border-radius: 15px;
            padding: 35px;
            overflow-y: auto;
            z-index: 2201;
            color: white;
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.3);
        }

        .rto-modal-close {
            position: absolute;
            top: 20px;
            right: 25px;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            color: rgba(255, 255, 255, 0.6);
            background: none;
            border: none;
            transition: color 0.3s;
        }

        .rto-modal-close:hover {
            color: rgba(255, 255, 255, 1);
        }

        .rto-modal-title {
            font-size: 1.8em;
            margin-bottom: 25px;
            color: #f97316;
            border-bottom: 2px solid rgba(249, 115, 22, 0.3);
            padding-bottom: 15px;
        }

        .rto-form-section {
            margin-bottom: 25px;
        }

        .rto-form-section-title {
            color: #23a6d5;
            font-size: 1.1em;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(35, 166, 213, 0.3);
            padding-bottom: 8px;
            font-weight: 600;
        }

        .rto-form-group {
            margin-bottom: 15px;
        }

        .rto-form-group label {
            display: block;
            margin-bottom: 8px;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 600;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .rto-form-group input,
        .rto-form-group textarea,
        .rto-form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            font-size: 0.95em;
            background: rgba(255, 255, 255, 0.05);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: all 0.3s;
        }

        .rto-form-group input:focus,
        .rto-form-group textarea:focus,
        .rto-form-group select:focus {
            outline: none;
            border-color: #f97316;
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2);
            background: rgba(255, 255, 255, 0.1);
        }

        .rto-form-group input::placeholder,
        .rto-form-group textarea::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .rto-checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .rto-checkbox-item {
            display: flex;
            align-items: flex-start;
            background: rgba(255, 255, 255, 0.05);
            padding: 12px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            cursor: pointer;
            transition: all 0.3s;
        }

        .rto-checkbox-item:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(249, 115, 22, 0.3);
        }

        .rto-checkbox-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            margin-right: 12px;
            margin-top: 2px;
            accent-color: #f97316;
        }

        .rto-checkbox-label {
            display: flex;
            flex-direction: column;
            flex: 1;
            color: rgba(255, 255, 255, 0.9);
            margin: 0;
            font-weight: 500;
            cursor: pointer;
        }

        .rto-checkbox-sublabel {
            font-size: 0.85em;
            color: rgba(255, 255, 255, 0.6);
            margin-top: 4px;
        }

        .rto-checkbox-item input[type="text"] {
            width: 100%;
            padding: 8px 12px;
            margin-top: 8px;
            font-size: 0.9em;
            border: 2px solid rgba(249, 115, 22, 0.3);
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.05);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: all 0.3s;
        }

        .rto-checkbox-item input[type="text"]:focus {
            outline: none;
            border-color: #f97316;
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2);
            background: rgba(255, 255, 255, 0.1);
        }

        .rto-checkbox-item input[type="text"]::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .rto-grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        @media (max-width: 768px) {
            .rto-grid-2 {
                grid-template-columns: 1fr;
            }

            .rto-modal-content {
                width: 98%;
                padding: 20px;
            }
        }

        .rto-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 25px;
        }

        .btn-submit-rto {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-submit-rto:hover {
            background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
            box-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
        }

        .btn-cancel-rto {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            padding: 12px 30px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-cancel-rto:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .rto-required {
            color: #ef4444;
        }

        .signature-canvas {
            border: 2px dashed rgba(249, 115, 22, 0.5);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.02);
            cursor: crosshair;
            display: block;
            width: 100%;
            height: 150px;
            margin-top: 10px;
        }

        .signature-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .btn-clear-signature {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            padding: 8px 16px;
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            font-size: 0.85em;
        }

        .btn-clear-signature:hover {
            background: rgba(239, 68, 68, 0.4);
        }
    </style>
</head>
<body>
    <div class="bg-animation">
        <div class="bg-gradient"></div>
        <div class="glow-orb glow-orb-1"></div>
        <div class="glow-orb glow-orb-2"></div>
        <div class="particles" id="particles"></div>
    </div>

    <div class="main-content">
        <!-- Hidden element to store technician data for JavaScript -->
        <div id="technicianData" data-technician-name="<%= technician ? technician.name : '' %>" style="display: none;"></div>
        
        <div class="header">
            <h1>📋 My Diagnostics</h1>
            <a class="btn-create" onclick="openCreateDiagnosticModal(); return false;" style="cursor: pointer;">+ Create New Diagnostic</a>
        </div>

        <div class="diagnostics-container">
            <table class="diagnostics-table" id="diagnosticsTable">
                <thead>
                    <tr>
                        <th>Diagnostic ID</th>
                        <th>Job Order ID</th>
                        <th>Customer</th>
                        <th>Problem</th>
                        <th>Status</th>
                        <th>Submitted Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="diagnosticsBody">
                    <!-- Populated by JavaScript -->
                </tbody>
            </table>

            <div id="emptyState" class="empty-state hidden">
                <h2>No Diagnostics Found</h2>
                <p>You haven't created any diagnostics yet.</p>
                <a href="/diagnostic" class="btn-create" style="display: inline-block;">Create Your First Diagnostic</a>
            </div>
        </div>
    </div>

    <!-- View Diagnostic Modal -->
    <div id="diagnosticModal" class="modal">
        <div class="modal-content">
            <span class="modal-close" onclick="closeDiagnosticModal()" style="position: absolute; top: 20px; right: 25px; font-size: 28px; font-weight: bold; cursor: pointer; color: rgba(255, 255, 255, 0.6);">&times;</span>
            
            <div class="modal-title">🔍 Diagnostic Details</div>

            <div class="diagnostic-details" id="diagnosticDetailsGrid"></div>

            <div class="images-gallery" id="imagesSection">
                <div class="gallery-title">📸 Images</div>
                <div class="gallery-grid" id="imagesGallery"></div>
            </div>

            <div id="videoSection">
                <div class="gallery-title">🎬 Video</div>
                <video width="100%" height="300" controls style="border-radius: 10px; border: 2px solid rgba(35, 166, 213, 0.3);">
                    <source id="videoSource" src="" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>

            <div id="materialsSection">
                <div class="gallery-title">🔧 Materials</div>
                <table class="materials-table">
                    <thead>
                        <tr>
                            <th>Material</th>
                            <th>Quantity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="materialsBody"></tbody>
                </table>
            </div>

            <div class="modal-actions">
                <button class="btn-close-modal" onclick="closeDiagnosticModal()">Close</button>
                <button class="btn-edit" id="editBtn" style="display: none;" onclick="openEditModal()">Edit</button>
                <button class="btn-delete" id="deleteBtn" style="display: none;" onclick="openDeleteModal()">Delete</button>
            </div>
        </div>
    </div>

    <!-- Edit Diagnostic Modal -->
    <div id="editDiagnosticModal" class="modal">
        <div class="edit-modal-content">
            <span class="modal-close" onclick="closeEditModal()" style="position: absolute; top: 15px; right: 20px; font-size: 26px; font-weight: bold; cursor: pointer; color: rgba(255, 255, 255, 0.6);">&times;</span>
            
            <div class="edit-modal-title">✏️ Edit Diagnostic</div>

            <form id="editDiagnosticForm" onsubmit="saveDiagnosticEdit(event)">
                <!-- Cost and Duration Section -->
                <div class="edit-form-section">
                    <h4 class="edit-form-section-title">💰 Estimation</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="edit-form-group">
                            <label for="editEstimatedCost">Estimated Cost (₱) *</label>
                            <input type="number" id="editEstimatedCost" placeholder="0.00" step="0.01" min="0" required>
                        </div>
                        <div class="edit-form-group">
                            <label for="editEstimatedDurationDate">Est. Complete Date *</label>
                            <input type="date" id="editEstimatedDurationDate" required>
                        </div>
                    </div>
                </div>

                <!-- Materials Section -->
                <div class="edit-form-section">
                    <h4 class="edit-form-section-title">🔧 Materials</h4>
                    <div class="edit-material-list" id="editMaterialsList">
                        <!-- Populated by JavaScript -->
                    </div>
                    <button type="button" class="btn-add-material" onclick="addEditMaterial()">+ Add Material</button>
                </div>

                <!-- Notes Section -->
                <div class="edit-form-section">
                    <h4 class="edit-form-section-title">📝 Notes</h4>
                    <div class="edit-form-group">
                        <label for="editNotes">Additional Notes</label>
                        <textarea id="editNotes" placeholder="Enter any additional notes..." rows="3"></textarea>
                    </div>
                </div>

                <input type="hidden" id="editDiagnosticId">

                <div class="edit-modal-actions">
                    <button type="button" class="btn-close-modal" onclick="closeEditModal()">Cancel</button>
                    <button type="submit" class="btn-save-edit">💾 Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteDiagnosticModal" class="modal">
        <div class="delete-modal-content">
            <span class="modal-close" onclick="closeDeleteModal()" style="position: absolute; top: 15px; right: 20px; font-size: 26px; font-weight: bold; cursor: pointer; color: rgba(255, 255, 255, 0.6);">&times;</span>
            
            <div class="delete-modal-icon">⚠️</div>
            <div class="delete-modal-title">Delete Diagnostic?</div>
            <div class="delete-modal-message">Are you sure you want to delete this diagnostic?</div>
            <div class="delete-modal-submessage">This action cannot be undone. All diagnostic data will be permanently removed.</div>
            
            <div class="delete-modal-actions">
                <button type="button" class="btn-close-modal" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn-confirm-delete" onclick="confirmDelete()">🗑️ Delete</button>
            </div>
        </div>
    </div>

    <!-- Create Diagnostic Modal -->
    <div id="createDiagnosticModal" class="create-diagnostic-modal" style="display: none;">
        <div class="create-diagnostic-modal-overlay" onclick="closeCreateDiagnosticModal()"></div>
        <div class="create-diagnostic-modal-content">
            <div class="create-diagnostic-modal-header">
                <h2>📋 Create Diagnostic Form</h2>
                <button class="create-diagnostic-modal-close" onclick="closeCreateDiagnosticModal()">&times;</button>
            </div>
            <div class="create-diagnostic-modal-body">
                <iframe id="diagnosticFormIframe" src="/diagnostic" style="width: 100%; height: 100%; border: none;"></iframe>
            </div>
        </div>
    </div>

    <!-- RTO Modal -->
    <div id="rtoModal" class="rto-modal">
        <div class="rto-modal-overlay" onclick="closeRTOModal()"></div>
        <div class="rto-modal-content">
            <button class="rto-modal-close" onclick="closeRTOModal()">×</button>
            <div class="rto-modal-title">📋 Return to Owner (RTO) Form</div>

            <form id="rtoForm" onsubmit="submitRTOForm(event)">
                <input type="hidden" id="rtoFormDiagnosticId">

                <!-- RTO Reason Section -->
                <div class="rto-form-section">
                    <h4 class="rto-form-section-title">🔴 Reason to Return To Owner</h4>
                    <div class="rto-form-group">
                        <label for="rtoReason">RTO Reason <span class="rto-required">*</span></label>
                        <select id="rtoReason" onchange="handleReasonChange()" required>
                            <option value="">-- Select Reason --</option>
                            <option value="Unit is Beyond Economic Repair">Unit is Beyond Economic Repair</option>
                            <option value="Parts not Available / Obsolete Model">Parts not Available / Obsolete Model</option>
                            <option value="Repair Cost Exceeds Device Value">Repair Cost Exceeds Device Value</option>
                            <option value="Customer Declined Repair Quotation">Customer Declined Repair Quotation</option>
                            <option value="Severe Liquid or Physical Damage">Severe Liquid or Physical Damage</option>
                            <option value="MotherBoard Failure (Unrepairable)">MotherBoard Failure (Unrepairable)</option>
                            <option value="Data not Recoverable">Data not Recoverable</option>
                            <option value="Customer Requested Pull Out">Customer Requested Pull Out</option>
                            <option value="Other Reason with Specify">Other Reason with Specify</option>
                        </select>
                    </div>

                    <div class="rto-form-group" id="rtoReasonSpecifySection" style="display: none;">
                        <label for="rtoReasonSpecify">Specify Reason</label>
                        <textarea id="rtoReasonSpecify" placeholder="Please specify the other reason..." rows="3"></textarea>
                    </div>

                    <div id="rtoEstimatedSection" style="display: none;">
                        <div class="rto-grid-2">
                            <div class="rto-form-group">
                                <label for="rtoEstimatedAmount">Estimated Amount (₱)</label>
                                <input type="number" id="rtoEstimatedAmount" placeholder="0.00" step="0.01" min="0">
                            </div>
                            <div class="rto-form-group">
                                <label for="rtoEstimatedDurationDate">Estimated Duration Date</label>
                                <input type="date" id="rtoEstimatedDurationDate">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Service Charge Section -->
                <div class="rto-form-section">
                    <h4 class="rto-form-section-title">💰 Service Charges</h4>
                    <div class="rto-grid-2">
                        <div class="rto-form-group">
                            <label for="rtoDiagnosticFee">Diagnostic Fee (₱)</label>
                            <input type="number" id="rtoDiagnosticFee" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                        </div>
                        <div class="rto-form-group">
                            <label for="rtoCleaningFee">Cleaning Fee (Optional) (₱)</label>
                            <input type="number" id="rtoCleaningFee" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                        </div>
                    </div>
                    <div class="rto-form-group">
                        <label for="rtoOtherCharges">Other Charges (If Any) (₱)</label>
                        <input type="number" id="rtoOtherCharges" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                    </div>
                    <div class="rto-form-group">
                        <label for="rtoTotalDue">Total Amount Due (₱) <span class="rto-required">*</span></label>
                        <input type="number" id="rtoTotalDue" placeholder="0.00" step="0.01" min="0" value="0" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>
                </div>

                <!-- Device Condition Section -->
                <div class="rto-form-section">
                    <h4 class="rto-form-section-title">📦 Device Condition upon Release</h4>
                    <label style="color: rgba(255, 255, 255, 0.8); font-size: 0.9em; margin-bottom: 12px; display: block;">Select all that apply (at least one required) <span class="rto-required">*</span></label>
                    <div class="rto-checkbox-group">
                        <label class="rto-checkbox-item">
                            <input type="checkbox" name="deviceCondition" value="Same as Received" onchange="handleDeviceConditionChange(this)">
                            <span class="rto-checkbox-label">Same as Received</span>
                        </label>
                        <label class="rto-checkbox-item">
                            <input type="checkbox" name="deviceCondition" value="With Scratches" onchange="handleDeviceConditionChange(this)">
                            <span class="rto-checkbox-label">With Scratches</span>
                        </label>
                        <label class="rto-checkbox-item">
                            <input type="checkbox" id="deviceConditionMissingParts" name="deviceCondition" value="With Missing Parts" onchange="handleDeviceConditionChange(this)">
                            <span class="rto-checkbox-label">With Missing Parts <span class="rto-checkbox-sublabel">(if any, must be specified below)</span></span>
                        </label>
                        <div id="missingPartsDescription" style="display: none; margin-left: 32px; margin-top: -6px;">
                            <input type="text" id="missingPartsSpecify" placeholder="Please specify missing parts..." style="width: calc(100% - 32px); padding: 8px 12px; border-radius: 6px; border: 2px solid rgba(249, 115, 22, 0.3); background: rgba(255, 255, 255, 0.05); color: white;">
                        </div>
                        <label class="rto-checkbox-item">
                            <input type="checkbox" name="deviceCondition" value="Opened for Diagnostic Only" onchange="handleDeviceConditionChange(this)">
                            <span class="rto-checkbox-label">Opened for Diagnostic Only</span>
                        </label>
                        <label class="rto-checkbox-item">
                            <input type="checkbox" name="deviceCondition" value="No Repair Performed" onchange="handleDeviceConditionChange(this)">
                            <span class="rto-checkbox-label">No Repair Performed</span>
                        </label>
                    </div>
                </div>

                <!-- Acknowledgement Section -->
                <div class="rto-form-section">
                    <h4 class="rto-form-section-title">✅ Acknowledgement Release</h4>
                    <div style="background: rgba(35, 166, 213, 0.1); padding: 15px; border-radius: 8px; border-left: 4px solid #23a6d5; margin-bottom: 20px;">
                        <p style="color: rgba(255, 255, 255, 0.85); line-height: 1.6;">
                            "I hereby acknowledge that I received my device in the condition stated above and understand the reason for Return to Owner (RTO)."
                        </p>
                    </div>

                    <div class="rto-grid-2">
                        <div class="rto-form-group">
                            <label for="rtoCustomerName">Customer Name <span class="rto-required">*</span></label>
                            <input type="text" id="rtoCustomerName" placeholder="Enter customer name" required>
                        </div>
                        <div class="rto-form-group">
                            <label for="rtoReceivedBy">Received By <span class="rto-required">*</span></label>
                            <input type="text" id="rtoReceivedBy" placeholder="Name of person who received device" required>
                        </div>
                    </div>

                    <div class="rto-form-group">
                        <label for="rtoTechnicianName">Technician Name (Automatic)</label>
                        <input type="text" id="rtoTechnicianName" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>

                    <div class="rto-form-group">
                        <label for="rtoDateReleased">Date Released (Automatic)</label>
                        <input type="date" id="rtoDateReleased" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>

                    <div class="rto-form-group">
                        <label>Digital Signature</label>
                        <canvas id="signatureCanvas" class="signature-canvas"></canvas>
                        <div class="signature-buttons">
                            <button type="button" class="btn-clear-signature" onclick="clearSignature()">Clear Signature</button>
                        </div>
                    </div>
                </div>

                <div class="rto-modal-actions">
                    <button type="button" class="btn-cancel-rto" onclick="closeRTOModal()">Cancel</button>
                    <button type="submit" class="btn-submit-rto">Submit RTO</button>
                </div>
            </form>
        </div>
    </div>

        let diagnosticsData = [];
        let currentDiagnostic = null;

        // Create floating particles
        const particlesContainer = document.getElementById('particles');
        const particleCount = 25;

        for (let i = 0; i < particleCount; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 5 + 's';
            particle.style.animationDuration = (4 + Math.random() * 3) + 's';
            
            const size = 3 + Math.random() * 6;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            
            particlesContainer.appendChild(particle);
        }

        // Initial load
        loadDiagnostics();

        // Check if we should open RTO modal for a specific diagnostic
        const openRTOModalForDiagnostic = sessionStorage.getItem('openRTOModalForDiagnostic');
        if (openRTOModalForDiagnostic) {
            sessionStorage.removeItem('openRTOModalForDiagnostic');
            setTimeout(() => {
                openRTOModal(openRTOModalForDiagnostic);
            }, 500);
        }

        function loadDiagnostics() {
            fetch('/api/diagnostic')
                .then(res => {
                    console.log('Diagnostics fetch response status:', res.status);
                    if (!res.ok) {
                        throw new Error(`HTTP error! status: ${res.status}`);
                    }
                    return res.json();
                })
                .then(data => {
                    console.log('Diagnostics data:', data);
                    if (data.success && data.diagnostics) {
                        diagnosticsData = data.diagnostics;
                        renderDiagnosticsTable();
                    } else {
                        const tbody = document.getElementById('diagnosticsBody');
                        tbody.innerHTML = '<tr><td colspan="8" class="empty-message">Error: ' + (data.message || 'Failed to load diagnostics') + '</td></tr>';
                    }
                })
                .catch(err => {
                    console.error('Error loading diagnostics:', err);
                    const tbody = document.getElementById('diagnosticsBody');
                    tbody.innerHTML = '<tr><td colspan="8" class="empty-message">Error: ' + err.message + '</td></tr>';
                });
        }

        function renderDiagnosticsTable() {
            const tbody = document.getElementById('diagnosticsBody');
            const emptyState = document.getElementById('emptyState');

            // Filter out diagnostics with RTO status
            const activeDiagnostics = diagnosticsData.filter(diag => diag.status !== 'RTO');

            if (activeDiagnostics.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                document.getElementById('diagnosticsTable').style.display = 'none';
                return;
            }

            emptyState.classList.add('hidden');
            document.getElementById('diagnosticsTable').style.display = 'table';

            tbody.innerHTML = activeDiagnostics.map(diag => `
                <tr onclick="viewDiagnostic('${diag.id}')">
                    <td>
                        <strong style="color: #23a6d5;">${diag.diagnosticId}</strong>
                    </td>
                    <td>${diag.jobOrderId}</td>
                    <td>${diag.customerName}</td>
                    <td>${Array.isArray(diag.problems) ? diag.problems.join(', ') : diag.problems || 'N/A'}</td>
                    <td>
                        <span class="status-badge status-${diag.status.toLowerCase().replace(' ', '-')}">
                            ${diag.status}
                        </span>
                    </td>
                    <td>${new Date(diag.createdAt).toLocaleDateString('en-PH')}</td>
                    <td>
                        <div class="action-buttons" onclick="event.stopPropagation();">
                            <button class="btn-view" onclick="viewDiagnostic('${diag.id}'); event.stopPropagation();">View</button>
                            ${diag.status === 'Pending' ? `<button class="btn-edit" onclick="editDiagnosticInit('${diag.id}'); event.stopPropagation();">Edit</button>` : ''}
                            ${diag.status === 'Pending' ? `<button class="btn-delete" onclick="deleteDiagnosticInit('${diag.id}'); event.stopPropagation();">Delete</button>` : ''}
                            ${diag.status === 'Completed' || diag.status === 'Pending' ? `<button class="btn-rto" onclick="openRTOModal('${diag.id}'); event.stopPropagation();">RTO</button>` : ''}
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function viewDiagnostic(diagnosticId) {
            fetch(`/api/diagnostic/${diagnosticId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        currentDiagnostic = data.diagnostic;
                        displayDiagnosticModal(data.diagnostic);
                    }
                })
                .catch(err => console.error('Error loading diagnostic:', err));
        }

        function displayDiagnosticModal(diag) {
            const detailsGrid = document.getElementById('diagnosticDetailsGrid');
            detailsGrid.innerHTML = `
                <div class="detail-item">
                    <div class="detail-label">Diagnostic ID</div>
                    <div class="detail-value">${diag.diagnosticId}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Job Order ID</div>
                    <div class="detail-value">${diag.jobOrderId}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Customer Name</div>
                    <div class="detail-value">${diag.customerName}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Device Type</div>
                    <div class="detail-value">${diag.deviceType}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Estimated Cost</div>
                    <div class="detail-value">₱${diag.estimatedCost.toFixed(2)}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Est. Completion</div>
                    <div class="detail-value">${new Date(diag.estimatedDurationDate).toLocaleDateString('en-PH')}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        <span class="status-badge status-${diag.status.toLowerCase().replace(' ', '-')}">
                            ${diag.status}
                        </span>
                    </div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Submitted Date</div>
                    <div class="detail-value">${new Date(diag.createdAt).toLocaleDateString('en-PH')}</div>
                </div>
            `;

            // Images Gallery
            if (diag.images && diag.images.length > 0) {
                const galleryHtml = diag.images.map((img, idx) => `
                    <div class="gallery-item" onclick="expandImage(${idx})" title="Click to view full size">
                        <img src="${img.data}" alt="Diagnostic Image ${idx + 1}">
                    </div>
                `).join('');
                document.getElementById('imagesGallery').innerHTML = galleryHtml;
                document.getElementById('imagesSection').style.display = 'block';
            } else {
                document.getElementById('imagesSection').style.display = 'none';
            }

            // Video
            const videoSection = document.getElementById('videoSection');
            const videoElement = videoSection.querySelector('video');
            if (diag.videoData && diag.videoData.data) {
                document.getElementById('videoSource').src = diag.videoData.data;
                videoElement.load();
                videoSection.style.display = 'block';
            } else {
                videoSection.style.display = 'none';
            }

            // Materials
            if (diag.materials && diag.materials.length > 0) {
                const materialsHtml = diag.materials.map(mat => `
                    <tr>
                        <td>${mat.name}</td>
                        <td>${mat.quantity}</td>
                        <td>${mat.outOfStock ? '<span class="out-of-stock-badge">Out of Stock</span>' : 'In Stock'}</td>
                    </tr>
                `).join('');
                document.getElementById('materialsBody').innerHTML = materialsHtml;
            }

            // Show/Hide action buttons based on status
            const editBtn = document.getElementById('editBtn');
            const deleteBtn = document.getElementById('deleteBtn');

            if (diag.status === 'Pending') {
                editBtn.style.display = 'inline-block';
                deleteBtn.style.display = 'inline-block';
            } else {
                editBtn.style.display = 'none';
                deleteBtn.style.display = 'none';
            }

            document.getElementById('diagnosticModal').style.display = 'block';
        }

        function closeDiagnosticModal() {
            document.getElementById('diagnosticModal').style.display = 'none';
            currentDiagnostic = null;
        }

        // Edit Modal Functions
        function editDiagnosticInit(diagnosticId) {
            viewDiagnostic(diagnosticId);
        }

        function openEditModal() {
            if (!currentDiagnostic || currentDiagnostic.status !== 'Pending') return;

            // Populate form with current diagnostic data
            document.getElementById('editDiagnosticId').value = currentDiagnostic.id;
            document.getElementById('editEstimatedCost').value = currentDiagnostic.estimatedCost;
            document.getElementById('editEstimatedDurationDate').value = currentDiagnostic.estimatedDurationDate ? currentDiagnostic.estimatedDurationDate.split('T')[0] : '';
            document.getElementById('editNotes').value = currentDiagnostic.notes || '';

            // Populate materials
            renderEditMaterials(currentDiagnostic.materials || []);

            // Close view modal and open edit modal
            document.getElementById('diagnosticModal').style.display = 'none';
            document.getElementById('editDiagnosticModal').style.display = 'block';
        }

        function renderEditMaterials(materials) {
            const container = document.getElementById('editMaterialsList');
            if (materials.length === 0) {
                // Add one empty material row if no materials
                container.innerHTML = createEditMaterialRow('');
            } else {
                container.innerHTML = materials.map(mat => createEditMaterialRow(mat.name, mat.quantity, mat.outOfStock)).join('');
            }
        }

        function createEditMaterialRow(name = '', quantity = 1, outOfStock = false) {
            return `
                <div class="edit-material-item">
                    <input type="text" placeholder="Material Name" class="material-name" value="${name}">
                    <input type="number" placeholder="Qty" class="material-qty" value="${quantity}" min="1" style="width: 80px;">
                    <div class="checkbox-group">
                        <input type="checkbox" class="material-out-of-stock" ${outOfStock ? 'checked' : ''}>
                        <label>Out</label>
                    </div>
                    <button type="button" class="btn-remove-material" onclick="removeEditMaterial(this)">✕</button>
                </div>
            `;
        }

        function addEditMaterial() {
            const container = document.getElementById('editMaterialsList');
            const newItem = document.createElement('div');
            newItem.className = 'edit-material-item';
            newItem.innerHTML = createEditMaterialRow();
            container.appendChild(newItem);
        }

        function removeEditMaterial(btn) {
            const container = document.getElementById('editMaterialsList');
            if (container.children.length > 1) {
                btn.parentElement.remove();
            } else {
                // Clear the last item instead of removing
                const item = btn.parentElement;
                item.querySelector('.material-name').value = '';
                item.querySelector('.material-qty').value = 1;
                item.querySelector('.material-out-of-stock').checked = false;
            }
        }

        function closeEditModal() {
            document.getElementById('editDiagnosticModal').style.display = 'none';
        }

        function saveDiagnosticEdit(event) {
            event.preventDefault();

            const diagnosticId = document.getElementById('editDiagnosticId').value;
            const estimatedCost = parseFloat(document.getElementById('editEstimatedCost').value);
            const estimatedDurationDate = document.getElementById('editEstimatedDurationDate').value;
            const notes = document.getElementById('editNotes').value;

            // Collect materials
            const materials = [];
            document.querySelectorAll('.edit-material-item').forEach(item => {
                const name = item.querySelector('.material-name').value.trim();
                const qty = parseInt(item.querySelector('.material-qty').value) || 1;
                const outOfStock = item.querySelector('.material-out-of-stock').checked;
                if (name) {
                    materials.push({ name, quantity: qty, outOfStock });
                }
            });

            const formData = {
                estimatedCost,
                estimatedDurationDate,
                notes,
                materials
            };

            fetch(`/api/diagnostic/${diagnosticId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification('Diagnostic updated successfully!', 'success');
                    closeEditModal();
                    loadDiagnostics();
                } else {
                    showNotification(data.message || 'Error updating diagnostic', 'error');
                }
            })
            .catch(err => showNotification('Error: ' + err.message, 'error'));
        }

        // Delete Modal Functions
        function deleteDiagnosticInit(diagnosticId) {
            // Fetch diagnostic first and directly open delete confirmation modal
            fetch(`/api/diagnostic/${diagnosticId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        currentDiagnostic = data.diagnostic;
                        // Directly open delete confirmation modal without showing view modal
                        document.getElementById('deleteDiagnosticModal').style.display = 'block';
                    } else {
                        showNotification('Error loading diagnostic: ' + (data.message || 'Unknown error'), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error loading diagnostic for delete:', err);
                    showNotification('Error: ' + err.message, 'error');
                });
        }

        function openDeleteModal() {
            if (!currentDiagnostic) return;
            document.getElementById('diagnosticModal').style.display = 'none';
            document.getElementById('deleteDiagnosticModal').style.display = 'block';
        }

        function closeDeleteModal() {
            document.getElementById('deleteDiagnosticModal').style.display = 'none';
        }

        function confirmDelete() {
            if (!currentDiagnostic) return;

            fetch(`/api/diagnostic/${currentDiagnostic.id}`, {
                method: 'DELETE'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification('Diagnostic deleted successfully', 'success');
                    closeDeleteModal();
                    loadDiagnostics();
                } else {
                    showNotification(data.message || 'Error deleting diagnostic', 'error');
                }
            })
            .catch(err => showNotification('Error: ' + err.message, 'error'));
        }

        function expandImage(index) {
            if (currentDiagnostic && currentDiagnostic.images[index]) {
                const img = currentDiagnostic.images[index];
                const modal = document.createElement('div');
                modal.className = 'modal';
                modal.style.display = 'block';
                modal.innerHTML = `
                    <div style="position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                        <span style="position: absolute; top: 20px; right: 40px; font-size: 40px; font-weight: bold; cursor: pointer; color: white; z-index: 2001;" onclick="this.parentElement.parentElement.remove();">&times;</span>
                        <img src="${img.data}" style="max-width: 90%; max-height: 90%; border-radius: 10px; box-shadow: 0 0 50px rgba(102, 126, 234, 0.8);">
                    </div>
                `;
                document.body.appendChild(modal);
            }
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.textContent = message;
            document.body.appendChild(notification);

            setTimeout(() => {
                notification.style.animation = 'slideOut 0.5s ease-in forwards';
                setTimeout(() => notification.remove(), 500);
            }, 4000);
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const viewModal = document.getElementById('diagnosticModal');
            const editModal = document.getElementById('editDiagnosticModal');
            const deleteModal = document.getElementById('deleteDiagnosticModal');
            
            if (event.target == viewModal) {
                viewModal.style.display = 'none';
            }
            if (event.target == editModal) {
                editModal.style.display = 'none';
            }
            if (event.target == deleteModal) {
                deleteModal.style.display = 'none';
            }
        }

        function openCreateDiagnosticModal() {
            const modal = document.getElementById('createDiagnosticModal');
            modal.style.display = 'block';
        }

        function closeCreateDiagnosticModal() {
            const modal = document.getElementById('createDiagnosticModal');
            modal.style.display = 'none';
            
            // Reset iframe src to reload the form fresh next time
            const iframe = document.getElementById('diagnosticFormIframe');
            if (iframe) {
                iframe.src = iframe.src;
            }
        }

        // Listen for messages from the diagnostic form iframe
        window.addEventListener('message', function(event) {
            if (event.data && event.data.type === 'diagnostic-created') {
                console.log('Diagnostic created:', event.data.diagnosticId);
                closeCreateDiagnosticModal();
                showNotification('Diagnostic created successfully!', 'success');
                loadDiagnostics();
            }
        });

        // Also listen for custom events from same origin
        window.addEventListener('diagnostic-created', function(e) {
            console.log('Diagnostic created via custom event:', e.detail);
            closeCreateDiagnosticModal();
            showNotification('Diagnostic created successfully!', 'success');
            loadDiagnostics();
        });

// RTO Functions
        // Get technician name from server API
        let technicianData = null;
        
        async function fetchTechnicianData() {
            try {
                // Try to get technician info from the page or API
                const response = await fetch('/api/technician/current');
                if (response.ok) {
                    const data = await response.json();
                    if (data.success) {
                        technicianData = data.technician;
                    }
                }
            } catch (err) {
                console.log('Could not fetch technician data:', err);
            }
        }

        function openRTOModal(diagnosticId) {
            const rtoModal = document.getElementById('rtoModal');
            document.getElementById('rtoFormDiagnosticId').value = diagnosticId;
            rtoModal.classList.add('show');
            
            // Auto-fill technician name from page data attribute or session
            const technicianName = document.querySelector('[data-technician-name]')?.getAttribute('data-technician-name') || 
                                   document.querySelector('.tech-info strong')?.textContent || 
                                   technicianData?.name || '';
            document.getElementById('rtoTechnicianName').value = technicianName;
            
            // Set current date for date released
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('rtoDateReleased').value = today;
        }
        
        // Function to open RTO modal for a specific diagnostic (used by rto-list page)
        function openRTOModalForDiagnostic(diagnosticId) {
            // First set the diagnostic ID
            document.getElementById('rtoFormDiagnosticId').value = diagnosticId;
            
            // Fetch diagnostic details to get customer name
            fetch(`/api/diagnostic/${diagnosticId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const diag = data.diagnostic;
                        // Auto-fill customer name from diagnostic
                        document.getElementById('rtoCustomerName').value = diag.customerName || '';
                        
                        // Pre-fill estimated amount and date from diagnostic if available
                        if (diag.estimatedCost) {
                            document.getElementById('rtoEstimatedAmount').value = diag.estimatedCost;
                        }
                        if (diag.estimatedDurationDate) {
                            document.getElementById('rtoEstimatedDurationDate').value = diag.estimatedDurationDate.split('T')[0];
                        }
                    }
                })
                .catch(err => console.error('Error fetching diagnostic:', err));
            
            // Auto-fill technician name
            const technicianName = document.querySelector('[data-technician-name]')?.getAttribute('data-technician-name') || 
                                   document.querySelector('.tech-info strong')?.textContent || 
                                   technicianData?.name || '';
            document.getElementById('rtoTechnicianName').value = technicianName;
            
            // Set current date for date released
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('rtoDateReleased').value = today;
            
            // Show the RTO modal
            const rtoModal = document.getElementById('rtoModal');
            rtoModal.classList.add('show');
        }

        function closeRTOModal() {
            const rtoModal = document.getElementById('rtoModal');
            rtoModal.classList.remove('show');
            resetRTOForm();
        }

        function resetRTOForm() {
            document.getElementById('rtoForm').reset();
            const canvas = document.getElementById('signatureCanvas');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        // Handle device condition checkbox - show input for missing parts
        function handleDeviceConditionChange(checkbox) {
            const missingPartsInput = document.getElementById('missingPartsDescription');
            const isMissingPartsChecked = document.getElementById('deviceConditionMissingParts').checked;
            
            if (isMissingPartsChecked) {
                missingPartsInput.style.display = 'block';
                document.getElementById('missingPartsSpecify').required = true;
            } else {
                missingPartsInput.style.display = 'none';
                document.getElementById('missingPartsSpecify').required = false;
                document.getElementById('missingPartsSpecify').value = '';
            }
        }

        // Calculate total service charge
        function calculateTotalDue() {
            const diagnosticFee = parseFloat(document.getElementById('rtoDiagnosticFee').value) || 0;
            const cleaningFee = parseFloat(document.getElementById('rtoCleaningFee').value) || 0;
            const otherCharges = parseFloat(document.getElementById('rtoOtherCharges').value) || 0;
            const total = diagnosticFee + cleaningFee + otherCharges;
            document.getElementById('rtoTotalDue').value = total.toFixed(2);
        }

        // Handle RTO form submission
        function submitRTOForm(event) {
            event.preventDefault();

            const diagnosticId = document.getElementById('rtoFormDiagnosticId').value;
            const reason = document.getElementById('rtoReason').value;
            const reasonSpecify = document.getElementById('rtoReasonSpecify').value;
            const estimatedAmount = document.getElementById('rtoEstimatedAmount').value;
            const estimatedDurationDate = document.getElementById('rtoEstimatedDurationDate').value;
            const diagnosticFee = document.getElementById('rtoDiagnosticFee').value;
            const cleaningFee = document.getElementById('rtoCleaningFee').value;
            const otherCharges = document.getElementById('rtoOtherCharges').value;
            const totalDue = document.getElementById('rtoTotalDue').value;
            const customerName = document.getElementById('rtoCustomerName').value;
            const receivedBy = document.getElementById('rtoReceivedBy').value;
            const technicianName = document.getElementById('rtoTechnicianName').value;

            // Get selected device conditions
            const deviceConditionCheckboxes = document.querySelectorAll('input[name="deviceCondition"]:checked');
            const deviceCondition = [];
            deviceConditionCheckboxes.forEach(cb => {
                deviceCondition.push(cb.value);
            });

            const missingPartsDescription = document.getElementById('deviceConditionMissingParts').checked
                ? document.getElementById('missingPartsSpecify').value
                : null;

            // Get digital signature
            const canvas = document.getElementById('signatureCanvas');
            const digitalSignature = canvas ? canvas.toDataURL() : null;

            if (!diagnosticId || !reason || !customerName || !receivedBy || deviceCondition.length === 0) {
                showNotification('Please fill in all required fields', 'error');
                return;
            }

            const rtoData = {
                diagnosticId,
                reason,
                reasonSpecify: reason === 'Other Reason with Specify' ? reasonSpecify : null,
                estimatedAmount,
                estimatedDurationDate,
                diagnosticFee,
                cleaningFee,
                otherCharges,
                totalDue,
                deviceCondition,
                missingPartsDescription,
                customerName,
                receivedBy,
                digitalSignature,
                technicianName
            };

            fetch('/api/rto/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(rtoData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification('RTO submitted successfully!', 'success');
                    closeRTOModal();
                    loadDiagnostics();
                } else {
                    showNotification('Error: ' + data.message, 'error');
                }
            })
            .catch(err => {
                console.error('Error submitting RTO:', err);
                showNotification('Error submitting RTO', 'error');
            });
        }

        // Handle reason change for conditional fields
        function handleReasonChange() {
            const reason = document.getElementById('rtoReason').value;
            const reasonSpecifySection = document.getElementById('rtoReasonSpecifySection');
            const estimatedSection = document.getElementById('rtoEstimatedSection');

            // Show reason specify field only for "Other Reason" option
            if (reason === 'Other Reason with Specify') {
                reasonSpecifySection.style.display = 'block';
                document.getElementById('rtoReasonSpecify').required = true;
            } else {
                reasonSpecifySection.style.display = 'none';
                document.getElementById('rtoReasonSpecify').required = false;
                document.getElementById('rtoReasonSpecify').value = '';
            }

            // Show estimated fields for "Customer Declined Repair Quotation"
            if (reason === 'Customer Declined Repair Quotation') {
                estimatedSection.style.display = 'block';
            } else {
                estimatedSection.style.display = 'none';
                document.getElementById('rtoEstimatedAmount').value = '';
                document.getElementById('rtoEstimatedDurationDate').value = '';
            }
        }

// Drawing signature functions
        let isDrawing = false;
        const canvas = document.getElementById('signatureCanvas');
        if (canvas) {
            // Set actual canvas size to match display size
            const rect = canvas.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;
            
            const ctx = canvas.getContext('2d');

            function getCanvasCoords(e) {
                const rect = canvas.getBoundingClientRect();
                const scaleX = canvas.width / rect.width;
                const scaleY = canvas.height / rect.height;
                return {
                    x: (e.clientX - rect.left) * scaleX,
                    y: (e.clientY - rect.top) * scaleY
                };
            }

            canvas.addEventListener('mousedown', (e) => {
                isDrawing = true;
                const coords = getCanvasCoords(e);
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
            });

            canvas.addEventListener('mousemove', (e) => {
                if (!isDrawing) return;
                const coords = getCanvasCoords(e);
                ctx.lineTo(coords.x, coords.y);
                ctx.strokeStyle = '#f97316';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                ctx.stroke();
            });

            canvas.addEventListener('mouseup', () => isDrawing = false);
            canvas.addEventListener('mouseout', () => isDrawing = false);
            
            // Touch support
            canvas.addEventListener('touchstart', (e) => {
                e.preventDefault();
                isDrawing = true;
                const touch = e.touches[0];
                const coords = getCanvasCoords(touch);
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
            });

            canvas.addEventListener('touchmove', (e) => {
                e.preventDefault();
                if (!isDrawing) return;
                const touch = e.touches[0];
                const coords = getCanvasCoords(touch);
                ctx.lineTo(coords.x, coords.y);
                ctx.strokeStyle = '#f97316';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                ctx.stroke();
            });

            canvas.addEventListener('touchend', () => isDrawing = false);
        }

        function clearSignature() {
            const canvas = document.getElementById('signatureCanvas');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }
    </script>
</body>
</html>
