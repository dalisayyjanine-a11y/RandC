<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RTO List - RNC System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            overflow: hidden;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            display: flex;
            position: relative;
        }

        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .bg-gradient {
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab, #f702a8, #0af);
            background-size: 400% 400%;
            animation: gradientBG 8s ease infinite;
            opacity: 0.25;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(50px);
            animation: orbFloat 10s ease-in-out infinite;
        }

        .glow-orb-1 {
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(102, 126, 234, 0.5) 0%, transparent 70%);
            top: -50px;
            left: -50px;
        }

        .glow-orb-2 {
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(118, 75, 162, 0.5) 0%, transparent 70%);
            bottom: -50px;
            right: -50px;
            animation-delay: -5s;
        }

        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(20px, -20px) scale(1.1); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .particle {
            position: absolute;
            width: 5px;
            height: 5px;
            background: rgba(255, 255, 255, 0.8);
            border-radius: 50%;
            animation: float 5s ease-in-out infinite;
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.6);
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
            50% { transform: translateY(-80px) rotate(180deg); opacity: 1; }
        }

        .main-content {
            position: relative;
            z-index: 1;
            width: 100%;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            padding: 25px 30px;
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.9) 0%, rgba(47, 43, 99, 0.9) 100%);
            border-bottom: 2px solid rgba(35, 166, 213, 0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
        }

        .header h1 {
            color: white;
            font-size: 2em;
            text-shadow: 0 0 15px rgba(35, 166, 213, 0.4);
            margin: 0;
        }

        .header-buttons {
            display: flex;
            gap: 15px;
            flex-direction: row-reverse;
        }

        .btn-back-dashboard,
        .btn-add-rto {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.95em;
            font-weight: 600;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .btn-back-dashboard {
            background: rgba(100, 116, 139, 0.2);
            color: #94a3b8;
            border: 1px solid rgba(100, 116, 139, 0.3);
        }

        .btn-back-dashboard:hover {
            background: rgba(100, 116, 139, 0.3);
            box-shadow: 0 0 15px rgba(100, 116, 139, 0.2);
        }

        .btn-add-rto {
            background: rgba(249, 115, 22, 0.2);
            color: #f97316;
            border: 1px solid rgba(249, 115, 22, 0.3);
        }

        .btn-add-rto:hover {
            background: rgba(249, 115, 22, 0.4);
            box-shadow: 0 0 15px rgba(249, 115, 22, 0.3);
        }

        .rtos-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px 30px;
        }

        .rtos-table {
            width: 100%;
            border-collapse: collapse;
            background: rgba(35, 42, 82, 0.7);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 0 30px rgba(102, 126, 234, 0.2);
            backdrop-filter: blur(10px);
        }

        .rtos-table thead {
            background: rgba(35, 166, 213, 0.2);
        }

        .rtos-table th {
            padding: 18px;
            text-align: left;
            color: #23a6d5;
            border-bottom: 2px solid rgba(35, 166, 213, 0.3);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9em;
        }

        .rtos-table tbody tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s;
            cursor: pointer;
        }

        .rtos-table tbody tr:hover {
            background: rgba(35, 166, 213, 0.15);
            box-shadow: inset 0 0 15px rgba(35, 166, 213, 0.1);
        }

        .rtos-table td {
            padding: 18px;
            vertical-align: middle;
            color: rgba(255, 255, 255, 0.9);
        }

        .status-badge {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .status-pending {
            background: rgba(59, 130, 246, 0.2);
            color: #3b82f6;
            border: 1px solid rgba(59, 130, 246, 0.4);
        }

        .status-completed {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
            border: 1px solid rgba(34, 197, 94, 0.4);
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-view,
        .btn-delete {
            padding: 8px 14px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85em;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-view {
            background: rgba(35, 166, 213, 0.2);
            color: #23a6d5;
            border: 1px solid rgba(35, 166, 213, 0.3);
        }

        .btn-view:hover {
            background: rgba(35, 166, 213, 0.4);
            box-shadow: 0 0 15px rgba(35, 166, 213, 0.3);
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.4);
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: rgba(255, 255, 255, 0.6);
        }

        .empty-state h2 {
            font-size: 1.8em;
            margin-bottom: 10px;
            color: rgba(255, 255, 255, 0.8);
        }

        .empty-state p {
            font-size: 1.1em;
            margin-bottom: 20px;
        }

        .hidden {
            display: none !important;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .modal.show {
            display: block;
        }

        .modal-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 95%;
            max-width: 900px;
            max-height: 90vh;
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.95) 0%, rgba(47, 43, 99, 0.95) 100%);
            border: 2px solid rgba(35, 166, 213, 0.3);
            border-radius: 15px;
            overflow-y: auto;
            padding: 35px;
            color: white;
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.3);
        }

        .modal-title {
            font-size: 1.6em;
            margin-bottom: 25px;
            color: #23a6d5;
            border-bottom: 2px solid rgba(35, 166, 213, 0.3);
            padding-bottom: 15px;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .detail-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .detail-label {
            color: #23a6d5;
            font-weight: 600;
            font-size: 0.9em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .detail-value {
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.05em;
            word-break: break-word;
        }

        .modal-actions {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 25px;
        }

        .btn-close-modal {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            padding: 10px 25px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-close-modal:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .btn-delete-rto {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            padding: 10px 25px;
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-delete-rto:hover {
            background: rgba(239, 68, 68, 0.4);
        }

        @media (max-width: 768px) {
            .rtos-table {
                font-size: 0.9em;
            }

            .rtos-table td,
            .rtos-table th {
                padding: 12px;
            }

            .action-buttons {
                flex-direction: column;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .header-buttons {
                width: 100%;
                flex-direction: column-reverse;
            }

            .btn-back-dashboard,
            .btn-add-rto {
                width: 100%;
                text-align: center;
            }
        }

        /* Add RTO Modal Styles */
        .add-rto-modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .add-rto-modal.show {
            display: block;
        }

        .add-rto-modal-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .add-rto-modal-content {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 95%;
            max-width: 600px;
            background: linear-gradient(135deg, rgba(35, 42, 82, 0.95) 0%, rgba(47, 43, 99, 0.95) 100%);
            border: 2px solid rgba(249, 115, 22, 0.3);
            border-radius: 15px;
            padding: 35px;
            z-index: 2001;
            color: white;
            box-shadow: 0 0 40px rgba(102, 126, 234, 0.3);
        }

        .add-rto-modal-close {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            color: rgba(255, 255, 255, 0.6);
            background: none;
            border: none;
            transition: color 0.3s;
        }

        .add-rto-modal-close:hover {
            color: rgba(255, 255, 255, 1);
        }

        .add-rto-modal-title {
            font-size: 1.8em;
            margin-bottom: 25px;
            color: #f97316;
            border-bottom: 2px solid rgba(249, 115, 22, 0.3);
            padding-bottom: 15px;
        }

        .add-rto-form-group {
            margin-bottom: 20px;
        }

        .add-rto-form-group label {
            display: block;
            margin-bottom: 8px;
            color: rgba(255, 255, 255, 0.9);
            font-weight: 600;
            font-size: 0.9em;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .add-rto-form-group input,
        .add-rto-form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            font-size: 0.95em;
            background: rgba(255, 255, 255, 0.05);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: all 0.3s;
        }

        .add-rto-form-group input:focus,
        .add-rto-form-group select:focus {
            outline: none;
            border-color: #f97316;
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2);
            background: rgba(255, 255, 255, 0.1);
        }

        .add-rto-form-group input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .add-rto-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 25px;
        }

        .btn-submit-add-rto {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-submit-add-rto:hover {
            background: linear-gradient(135deg, #ea580c 0%, #c2410c 100%);
            box-shadow: 0 0 20px rgba(249, 115, 22, 0.4);
        }

        .btn-cancel-add-rto {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            padding: 12px 30px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-cancel-add-rto:hover {
            background: rgba(255, 255, 255, 0.25);
        }
    </style>
</head>
<body>
    <div class="bg-animation">
        <div class="bg-gradient"></div>
        <div class="glow-orb glow-orb-1"></div>
        <div class="glow-orb glow-orb-2"></div>
        <div class="particles" id="particles"></div>
    </div>

    <div class="main-content">
        <div class="header">
            <!-- Hidden element to store technician data -->
            <span class="header-info" id="techInfoData" 
                data-tech-name="<%= technician ? technician.name : '' %>" 
                data-tech-id="<%= technician ? technician.id : '' %>"
                style="display: none;"></span>
            <div class="header-buttons">
                <button class="btn-back-dashboard" onclick="backToDashboard()">← Back to Dashboard</button>
                <button class="btn-add-rto" onclick="openAddRTOModal()">+ Create RTO</button>
            </div>
            <h1>📋 Return to Owner (RTO) List</h1>
        </div>

        <div class="rtos-container">
            <table class="rtos-table" id="rtosTable">
                <thead>
                    <tr>
                        <th>Diagnostic ID</th>
                        <th>Job Order ID</th>
                        <th>RTO Reason</th>
                        <th>Total Due</th>
                        <th>Released Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="rtosBody">
                    <!-- Populated by JavaScript -->
                </tbody>
            </table>

            <div id="emptyState" class="empty-state hidden">
                <h2>No RTOs Found</h2>
                <p>You haven't created any Return to Owner records yet.</p>
            </div>
        </div>
    </div>

    <!-- View RTO Modal -->
    <div id="rtoModal" class="modal">
        <div class="modal-overlay" onclick="closeRTOModal()"></div>
        <div class="modal-content">
            <span class="modal-close" onclick="closeRTOModal()" style="position: absolute; top: 20px; right: 25px; font-size: 28px; font-weight: bold; cursor: pointer; color: rgba(255, 255, 255, 0.6);">&times;</span>
            
            <div class="modal-title">🔍 RTO Details</div>

            <div class="detail-grid" id="rtoDetailsGrid"></div>

            <div style="margin-top: 25px;">
                <h3 style="color: #23a6d5; margin-bottom: 15px;">Service Charges</h3>
                <div class="detail-grid" id="serviceChargesGrid"></div>
            </div>

            <div style="margin-top: 25px;">
                <h3 style="color: #23a6d5; margin-bottom: 15px;">Device Condition</h3>
                <div id="deviceConditionDisplay" style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1);"></div>
            </div>

            <div style="margin-top: 25px;">
                <h3 style="color: #23a6d5; margin-bottom: 15px;">Acknowledgement</h3>
                <div class="detail-grid" id="acknowledgementGrid"></div>
            </div>

            <div class="modal-actions">
                <button class="btn-close-modal" onclick="closeRTOModal()">Close</button>
                <button class="btn-delete-rto" id="deleteRTOBtn" onclick="deleteRTORecord()">Delete RTO</button>
            </div>
        </div>
    </div>

    <!-- Add RTO Modal -->
    <div id="addRTOModal" class="add-rto-modal">
        <div class="add-rto-modal-overlay" onclick="closeAddRTOModal()"></div>
        <div class="add-rto-modal-content">
            <button class="add-rto-modal-close" onclick="closeAddRTOModal()">×</button>
            <div class="add-rto-modal-title">📋 Create RTO from Diagnosis</div>

            <form id="addRTOForm" onsubmit="submitAddRTOForm(event)">
                <div class="add-rto-form-group">
                    <label for="addRTODiagnosticId">Select Diagnostic ID <span style="color: #ef4444;">*</span></label>
                    <select id="addRTODiagnosticId" required onchange="updateDiagnosticInfo()">
                        <option value="">-- Select a Diagnostic --</option>
                    </select>
                </div>

                <div class="add-rto-form-group">
                    <label>Diagnostic Details</label>
                    <div style="background: rgba(255, 255, 255, 0.05); padding: 15px; border-radius: 10px; border: 1px solid rgba(255, 255, 255, 0.1);">
                        <p style="margin: 8px 0; color: rgba(255, 255, 255, 0.8);"><strong>Job Order ID:</strong> <span id="diagJobOrderId">N/A</span></p>
                        <p style="margin: 8px 0; color: rgba(255, 255, 255, 0.8);"><strong>Customer:</strong> <span id="diagCustomerName">N/A</span></p>
                        <p style="margin: 8px 0; color: rgba(255, 255, 255, 0.8);"><strong>Device:</strong> <span id="diagDeviceType">N/A</span></p>
                    </div>
                </div>

                <div class="add-rto-modal-actions">
                    <button type="button" class="btn-cancel-add-rto" onclick="closeAddRTOModal()">Cancel</button>
                    <button type="submit" class="btn-submit-add-rto">Create RTO</button>
</div>
            </form>
        </div>
    </div>

    <!-- Full RTO Modal with Complete Form -->
    <div id="rtoFullModal" class="modal">
        <div class="modal-overlay" onclick="closeFullRTOModal()"></div>
        <div class="modal-content" style="max-width: 1000px; max-height: 90vh;">
            <span class="modal-close" onclick="closeFullRTOModal()" style="position: absolute; top: 15px; right: 20px; font-size: 28px; font-weight: bold; cursor: pointer; color: rgba(255, 255, 255, 0.6);">&times;</span>
            
            <div class="modal-title" style="color: #f97316; border-bottom-color: rgba(249, 115, 22, 0.3);">📋 Return to Owner (RTO) Form</div>

            <form id="rtoFullForm" onsubmit="submitFullRTOForm(event)">
                <input type="hidden" id="rtoFormDiagnosticId">

                <!-- RTO Reason Section -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #23a6d5; font-size: 1.1em; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(35, 166, 213, 0.3); padding-bottom: 8px;">🔴 Reason to Return To Owner</h4>
                    
                    <div class="add-rto-form-group">
                        <label for="rtoReasonFull">RTO Reason <span style="color: #ef4444;">*</span></label>
                        <select id="rtoReasonFull" onchange="handleReasonChangeFull()" required>
                            <option value="">-- Select Reason --</option>
                            <option value="Unit is Beyond Economic Repair">Unit is Beyond Economic Repair</option>
                            <option value="Parts not Available / Obsolete Model">Parts not Available / Obsolete Model</option>
                            <option value="Repair Cost Exceeds Device Value">Repair Cost Exceeds Device Value</option>
                            <option value="Customer Declined Repair Quotation">Customer Declined Repair Quotation</option>
                            <option value="Severe Liquid or Physical Damage">Severe Liquid or Physical Damage</option>
                            <option value="MotherBoard Failure (Unrepairable)">MotherBoard Failure (Unrepairable)</option>
                            <option value="Data not Recoverable">Data not Recoverable</option>
                            <option value="Customer Requested Pull Out">Customer Requested Pull Out</option>
                            <option value="Other Reason with Specify">Other Reason with Specify</option>
                        </select>
                    </div>

                    <div class="add-rto-form-group" id="rtoReasonSpecifySectionFull" style="display: none;">
                        <label for="rtoReasonSpecifyFull">Specify Reason</label>
                        <textarea id="rtoReasonSpecifyFull" placeholder="Please specify the other reason..." rows="3" style="width: 100%; padding: 12px 15px; border: 2px solid rgba(255, 255, 255, 0.15); border-radius: 10px; font-size: 0.95em; background: rgba(255, 255, 255, 0.05); color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;"></textarea>
                    </div>

                    <div id="rtoEstimatedSectionFull" style="display: none;">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                            <div class="add-rto-form-group">
                                <label for="rtoEstimatedAmountFull">Estimated Amount (₱)</label>
                                <input type="number" id="rtoEstimatedAmountFull" placeholder="0.00" step="0.01" min="0">
                            </div>
                            <div class="add-rto-form-group">
                                <label for="rtoEstimatedDurationDateFull">Estimated Duration Date</label>
                                <input type="date" id="rtoEstimatedDurationDateFull">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Service Charge Section -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #23a6d5; font-size: 1.1em; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(35, 166, 213, 0.3); padding-bottom: 8px;">💰 Service Charges</h4>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="add-rto-form-group">
                            <label for="rtoDiagnosticFeeFull">Diagnostic Fee (₱)</label>
                            <input type="number" id="rtoDiagnosticFeeFull" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                        </div>
                        <div class="add-rto-form-group">
                            <label for="rtoCleaningFeeFull">Cleaning Fee (Optional) (₱)</label>
                            <input type="number" id="rtoCleaningFeeFull" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                        </div>
                    </div>
                    <div class="add-rto-form-group">
                        <label for="rtoOtherChargesFull">Other Charges (If Any) (₱)</label>
                        <input type="number" id="rtoOtherChargesFull" placeholder="0.00" step="0.01" min="0" value="0" onchange="calculateTotalDue()">
                    </div>
                    <div class="add-rto-form-group">
                        <label for="rtoTotalDueFull">Total Amount Due (₱) <span style="color: #ef4444;">*</span></label>
                        <input type="number" id="rtoTotalDueFull" placeholder="0.00" step="0.01" min="0" value="0" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>
                </div>

                <!-- Device Condition Section -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #23a6d5; font-size: 1.1em; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(35, 166, 213, 0.3); padding-bottom: 8px;">📦 Device Condition upon Release</h4>
                    
                    <label style="color: rgba(255, 255, 255, 0.8); font-size: 0.9em; margin-bottom: 12px; display: block;">Select all that apply (at least one required) <span style="color: #ef4444;">*</span></label>
                    
                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <label style="display: flex; align-items: flex-start; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer;">
                            <input type="checkbox" name="deviceConditionFull" value="Same as Received" style="width: 20px; height: 20px; margin-right: 12px; accent-color: #f97316;">
                            <span style="color: rgba(255, 255, 255, 0.9); font-weight: 500;">Same as Received</span>
                        </label>
                        <label style="display: flex; align-items: flex-start; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer;">
                            <input type="checkbox" name="deviceConditionFull" value="With Scratches" style="width: 20px; height: 20px; margin-right: 12px; accent-color: #f97316;">
                            <span style="color: rgba(255, 255, 255, 0.9); font-weight: 500;">With Scratches</span>
                        </label>
                        <label style="display: flex; align-items: flex-start; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer;">
                            <input type="checkbox" id="deviceConditionMissingPartsFull" name="deviceConditionFull" value="With Missing Parts" onchange="handleDeviceConditionChange()" style="width: 20px; height: 20px; margin-right: 12px; accent-color: #f97316;">
                            <span style="color: rgba(255, 255, 255, 0.9); font-weight: 500;">With Missing Parts <span style="font-size: 0.85em; color: rgba(255, 255, 255, 0.6);">(if any, must be specified below)</span></span>
                        </label>
                        <div id="missingPartsDescriptionFull" style="display: none; margin-left: 32px; margin-top: -6px;">
                            <input type="text" id="missingPartsSpecifyFull" placeholder="Please specify missing parts..." style="width: calc(100% - 32px); padding: 8px 12px; border-radius: 6px; border: 2px solid rgba(249, 115, 22, 0.3); background: rgba(255, 255, 255, 0.05); color: white;">
                        </div>
                        <label style="display: flex; align-items: flex-start; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer;">
                            <input type="checkbox" name="deviceConditionFull" value="Opened for Diagnostic Only" style="width: 20px; height: 20px; margin-right: 12px; accent-color: #f97316;">
                            <span style="color: rgba(255, 255, 255, 0.9); font-weight: 500;">Opened for Diagnostic Only</span>
                        </label>
                        <label style="display: flex; align-items: flex-start; background: rgba(255, 255, 255, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); cursor: pointer;">
                            <input type="checkbox" name="deviceConditionFull" value="No Repair Performed" style="width: 20px; height: 20px; margin-right: 12px; accent-color: #f97316;">
                            <span style="color: rgba(255, 255, 255, 0.9); font-weight: 500;">No Repair Performed</span>
                        </label>
                    </div>
                </div>

                <!-- Acknowledgement Section -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #23a6d5; font-size: 1.1em; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid rgba(35, 166, 213, 0.3); padding-bottom: 8px;">✅ Acknowledgement Release</h4>
                    
                    <div style="background: rgba(35, 166, 213, 0.1); padding: 15px; border-radius: 8px; border-left: 4px solid #23a6d5; margin-bottom: 20px;">
                        <p style="color: rgba(255, 255, 255, 0.85); line-height: 1.6;">
                            "I hereby acknowledge that I received my device in the condition stated above and understand the reason for Return to Owner (RTO)."
                        </p>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="add-rto-form-group">
                            <label for="rtoCustomerName">Customer Name <span style="color: #ef4444;">*</span></label>
                            <input type="text" id="rtoCustomerName" placeholder="Enter customer name" required>
                        </div>
                        <div class="add-rto-form-group">
                            <label for="rtoReceivedByFull">Received By <span style="color: #ef4444;">*</span></label>
                            <input type="text" id="rtoReceivedByFull" placeholder="Name of person who received device" required>
                        </div>
                    </div>

                    <div class="add-rto-form-group">
                        <label for="rtoTechnicianName">Technician Name (Automatic)</label>
                        <input type="text" id="rtoTechnicianName" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>

                    <div class="add-rto-form-group">
                        <label for="rtoDateReleased">Date Released (Automatic)</label>
                        <input type="date" id="rtoDateReleased" readonly style="background: rgba(255, 255, 255, 0.03);">
                    </div>

                    <div class="add-rto-form-group">
                        <label>Digital Signature</label>
                        <canvas id="signatureCanvasFull" style="border: 2px dashed rgba(249, 115, 22, 0.5); border-radius: 8px; background: rgba(255, 255, 255, 0.02); cursor: crosshair; display: block; width: 100%; height: 150px; margin-top: 10px;"></canvas>
                        <div style="display: flex; gap: 10px; margin-top: 10px;">
                            <button type="button" onclick="clearSignatureFull()" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; padding: 8px 16px; border: 1px solid rgba(239, 68, 68, 0.3); border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.85em;">Clear Signature</button>
                        </div>
                    </div>
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn-close-modal" onclick="closeFullRTOModal()">Cancel</button>
                    <button type="submit" class="btn-submit-add-rto">Submit RTO</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let rtosData = [];
        let currentRTO = null;
        let isDrawing = false;

        // Particle animation
        const particlesContainer = document.getElementById('particles');
        for (let i = 0; i < 50; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.top = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 5 + 's';
            particle.style.animationDuration = (Math.random() * 5 + 5) + 's';
            
            const size = Math.random() * 5 + 2;
            particle.style.width = size + 'px';
            particle.style.height = size + 'px';
            
            particlesContainer.appendChild(particle);
        }

        // Load RTOs on page load
        loadRTOs();

        function loadRTOs() {
            fetch('/api/rto')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.rtos) {
                        rtosData = data.rtos;
                        renderRTOsTable();
                    } else {
                        console.error(data.message);
                        const tbody = document.getElementById('rtosBody');
                        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: #ef4444;">Error loading RTOs</td></tr>';
                    }
                })
                .catch(err => {
                    console.error('Error loading RTOs:', err);
                    const tbody = document.getElementById('rtosBody');
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: #ef4444;">Error loading RTOs</td></tr>';
                });
        }

        function renderRTOsTable() {
            const tbody = document.getElementById('rtosBody');
            const emptyState = document.getElementById('emptyState');

            if (rtosData.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                document.getElementById('rtosTable').style.display = 'none';
                return;
            }

            emptyState.classList.add('hidden');
            document.getElementById('rtosTable').style.display = 'table';

            tbody.innerHTML = rtosData.map(rto => `
                <tr onclick="viewRTO('${rto.id}')">
                    <td>
                        <strong style="color: #23a6d5;">${rto.diagnosticId}</strong>
                    </td>
                    <td>${rto.jobOrderId}</td>
                    <td>${rto.reason}</td>
                    <td>₱${parseFloat(rto.serviceCharges?.totalDue || 0).toFixed(2)}</td>
                    <td>${new Date(rto.dateReleased).toLocaleDateString('en-PH')}</td>
                    <td>
                        <div class="action-buttons" onclick="event.stopPropagation();">
                            <button class="btn-view" onclick="viewRTO('${rto.id}'); event.stopPropagation();">View</button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function viewRTO(rtoId) {
            fetch(`/api/rto/${rtoId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        currentRTO = data.rto;
                        displayRTOModal(data.rto);
                    }
                })
                .catch(err => console.error('Error loading RTO:', err));
        }

        function displayRTOModal(rto) {
            const detailsGrid = document.getElementById('rtoDetailsGrid');
            detailsGrid.innerHTML = `
                <div class="detail-item">
                    <div class="detail-label">Diagnostic ID</div>
                    <div class="detail-value">${rto.diagnosticId}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Job Order ID</div>
                    <div class="detail-value">${rto.jobOrderId}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">RTO Reason</div>
                    <div class="detail-value">${rto.reason}</div>
                </div>
                ${rto.reasonSpecify ? `
                <div class="detail-item">
                    <div class="detail-label">Reason Specification</div>
                    <div class="detail-value">${rto.reasonSpecify}</div>
                </div>
                ` : ''}
                ${rto.estimatedAmount ? `
                <div class="detail-item">
                    <div class="detail-label">Estimated Amount</div>
                    <div class="detail-value">₱${parseFloat(rto.estimatedAmount).toFixed(2)}</div>
                </div>
                ` : ''}
                ${rto.estimatedDurationDate ? `
                <div class="detail-item">
                    <div class="detail-label">Estimated Duration Date</div>
                    <div class="detail-value">${new Date(rto.estimatedDurationDate).toLocaleDateString('en-PH')}</div>
                </div>
                ` : ''}
                <div class="detail-item">
                    <div class="detail-label">Date Released</div>
                    <div class="detail-value">${new Date(rto.dateReleased).toLocaleDateString('en-PH')}</div>
                </div>
            `;

            // Service Charges
            const serviceChargesGrid = document.getElementById('serviceChargesGrid');
            const charges = rto.serviceCharges || {};
            serviceChargesGrid.innerHTML = `
                <div class="detail-item">
                    <div class="detail-label">Diagnostic Fee</div>
                    <div class="detail-value">₱${parseFloat(charges.diagnosticFee || 0).toFixed(2)}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Cleaning Fee</div>
                    <div class="detail-value">₱${parseFloat(charges.cleaningFee || 0).toFixed(2)}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Other Charges</div>
                    <div class="detail-value">₱${parseFloat(charges.otherCharges || 0).toFixed(2)}</div>
                </div>
                <div class="detail-item" style="grid-column: 1 / -1; background: rgba(34, 197, 94, 0.2); border-color: rgba(34, 197, 94, 0.4);">
                    <div class="detail-label">Total Due</div>
                    <div class="detail-value" style="color: #22c55e; font-size: 1.3em; font-weight: 600;">₱${parseFloat(charges.totalDue || 0).toFixed(2)}</div>
                </div>
            `;

            // Device Condition
            const deviceConditionDisplay = document.getElementById('deviceConditionDisplay');
            const conditions = Array.isArray(rto.deviceCondition) ? rto.deviceCondition : [rto.deviceCondition];
            const conditionText = conditions.map(c => {
                if (c === 'With Missing Parts') {
                    return `<li>${c} - ${rto.missingPartsDescription || 'Not specified'}</li>`;
                }
                return `<li>${c}</li>`;
            }).join('');
            deviceConditionDisplay.innerHTML = `<ul style="color: rgba(255, 255, 255, 0.9); line-height: 1.8;">${conditionText}</ul>`;

            // Acknowledgement
            const acknowledgementGrid = document.getElementById('acknowledgementGrid');
            const ack = rto.acknowledgement || {};
            acknowledgementGrid.innerHTML = `
                <div class="detail-item">
                    <div class="detail-label">Customer Name</div>
                    <div class="detail-value">${ack.customerName}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Received By</div>
                    <div class="detail-value">${ack.receivedBy}</div>
                </div>
                <div class="detail-item">
                    <div class="detail-label">Technician Name</div>
                    <div class="detail-value">${rto.technicianName}</div>
                </div>
                ${ack.digitalSignature ? `
                <div class="detail-item" style="grid-column: 1 / -1;">
                    <div class="detail-label">Digital Signature</div>
                    <img src="${ack.digitalSignature}" style="max-width: 200px; max-height: 100px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.2);" alt="Digital Signature">
                </div>
                ` : ''}
            `;

            document.getElementById('rtoModal').classList.add('show');
        }

        function closeRTOModal() {
            document.getElementById('rtoModal').classList.remove('show');
            currentRTO = null;
        }

        function deleteRTORecord() {
            if (!currentRTO) return;
            
            if (!confirm('Are you sure you want to delete this RTO record?')) return;

            fetch(`/api/rto/${currentRTO.id}`, {
                method: 'DELETE'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeRTOModal();
                    loadRTOs();
                    alert('RTO deleted successfully');
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(err => {
                console.error('Error deleting RTO:', err);
                alert('Error deleting RTO');
            });
        }

        // Close modal when clicking overlay
        document.getElementById('rtoModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeRTOModal();
            }
        });

        // Back to Dashboard function
        function backToDashboard() {
            window.location.href = '/technician-dashboard';
        }

// Add RTO Modal functions
        let diagnosticsForRTO = [];

        function openAddRTOModal() {
            // Fetch available diagnostics that don't have RTO yet
            fetch('/api/diagnostic')
                .then(res => res.json())
                .then(data => {
                    if (data.success && data.diagnostics) {
                        diagnosticsForRTO = data.diagnostics.filter(d => d.status !== 'RTO');
                        
                        const select = document.getElementById('addRTODiagnosticId');
                        select.innerHTML = '<option value="">-- Select a Diagnostic --</option>';
                        
                        diagnosticsForRTO.forEach(diag => {
                            const option = document.createElement('option');
                            option.value = diag.id;
                            option.textContent = `${diag.diagnosticId} - ${diag.customerName} (${diag.deviceType})`;
                            select.appendChild(option);
                        });
                    }
                })
                .catch(err => console.error('Error loading diagnostics:', err));
            
            document.getElementById('addRTOModal').classList.add('show');
        }

        function closeAddRTOModal() {
            document.getElementById('addRTOModal').classList.remove('show');
            document.getElementById('addRTOForm').reset();
            document.getElementById('diagJobOrderId').textContent = 'N/A';
            document.getElementById('diagCustomerName').textContent = 'N/A';
            document.getElementById('diagDeviceType').textContent = 'N/A';
        }

        function updateDiagnosticInfo() {
            const diagnosticId = document.getElementById('addRTODiagnosticId').value;
            const diagnostic = diagnosticsForRTO.find(d => d.id === diagnosticId);
            
            if (diagnostic) {
                document.getElementById('diagJobOrderId').textContent = diagnostic.jobOrderId;
                document.getElementById('diagCustomerName').textContent = diagnostic.customerName;
                document.getElementById('diagDeviceType').textContent = diagnostic.deviceType;
            } else {
                document.getElementById('diagJobOrderId').textContent = 'N/A';
                document.getElementById('diagCustomerName').textContent = 'N/A';
                document.getElementById('diagDeviceType').textContent = 'N/A';
            }
        }

        function submitAddRTOForm(event) {
            event.preventDefault();
            
            const diagnosticId = document.getElementById('addRTODiagnosticId').value;
            
            if (!diagnosticId) {
                alert('Please select a diagnostic');
                return;
            }

            // Open RTO modal directly on this page with the selected diagnostic
            openFullRTOModal(diagnosticId);
            closeAddRTOModal();
        }

        // Initialize signature canvas
        function initSignatureCanvas() {
            const canvas = document.getElementById('signatureCanvasFull');
            if (canvas) {
                // Set actual canvas size to match display size
                const rect = canvas.getBoundingClientRect();
                canvas.width = rect.width;
                canvas.height = rect.height;

                const ctx = canvas.getContext('2d');

                function getCanvasCoords(e) {
                    const rect = canvas.getBoundingClientRect();
                    const scaleX = canvas.width / rect.width;
                    const scaleY = canvas.height / rect.height;
                    return {
                        x: (e.clientX - rect.left) * scaleX,
                        y: (e.clientY - rect.top) * scaleY
                    };
                }

                canvas.addEventListener('mousedown', (e) => {
                    isDrawing = true;
                    const coords = getCanvasCoords(e);
                    ctx.beginPath();
                    ctx.moveTo(coords.x, coords.y);
                });

                canvas.addEventListener('mousemove', (e) => {
                    if (!isDrawing) return;
                    const coords = getCanvasCoords(e);
                    ctx.lineTo(coords.x, coords.y);
                    ctx.strokeStyle = '#f97316';
                    ctx.lineWidth = 2;
                    ctx.lineCap = 'round';
                    ctx.lineJoin = 'round';
                    ctx.stroke();
                });

                canvas.addEventListener('mouseup', () => isDrawing = false);
                canvas.addEventListener('mouseout', () => isDrawing = false);

                // Touch support
                canvas.addEventListener('touchstart', (e) => {
                    e.preventDefault();
                    isDrawing = true;
                    const touch = e.touches[0];
                    const coords = getCanvasCoords(touch);
                    ctx.beginPath();
                    ctx.moveTo(coords.x, coords.y);
                });

                canvas.addEventListener('touchmove', (e) => {
                    e.preventDefault();
                    if (!isDrawing) return;
                    const touch = e.touches[0];
                    const coords = getCanvasCoords(touch);
                    ctx.lineTo(coords.x, coords.y);
                    ctx.strokeStyle = '#f97316';
                    ctx.lineWidth = 2;
                    ctx.lineCap = 'round';
                    ctx.lineJoin = 'round';
                    ctx.stroke();
                });

                canvas.addEventListener('touchend', () => isDrawing = false);
            }
        }

        // Full RTO Modal Functions - Integrated from diagnostic-list
function openFullRTOModal(diagnosticId) {
            const rtoModal = document.getElementById('rtoFullModal');
            document.getElementById('rtoFormDiagnosticId').value = diagnosticId;
            rtoModal.classList.add('show');
            
            // Initialize signature canvas after modal is shown
            setTimeout(initSignatureCanvas, 100);
            
            // Fetch diagnostic details to auto-fill
            fetch(`/api/diagnostic/${diagnosticId}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const diag = data.diagnostic;
                        // Auto-fill customer name
                        document.getElementById('rtoCustomerName').value = diag.customerName || '';
                        // Pre-fill estimated amount and date
                        if (diag.estimatedCost) {
                            document.getElementById('rtoEstimatedAmount').value = diag.estimatedCost;
                        }
                        if (diag.estimatedDurationDate) {
                            document.getElementById('rtoEstimatedDurationDate').value = diag.estimatedDurationDate.split('T')[0];
                        }
                    }
                })
                .catch(err => console.error('Error fetching diagnostic:', err));
            
            // Auto-fill technician name from page (session data)
            const techInfo = document.getElementById('techInfoData');
            if (techInfo) {
                document.getElementById('rtoTechnicianName').value = techInfo.getAttribute('data-tech-name') || '';
            }
            
            // Set current date for date released
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('rtoDateReleased').value = today;
        }

        function closeFullRTOModal() {
            document.getElementById('rtoFullModal').classList.remove('show');
            resetFullRTOForm();
        }

        function resetFullRTOForm() {
            document.getElementById('rtoFullForm').reset();
            const canvas = document.getElementById('signatureCanvasFull');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        // Handle device condition checkbox
        function handleDeviceConditionChange() {
            const missingPartsInput = document.getElementById('missingPartsDescriptionFull');
            const isMissingPartsChecked = document.getElementById('deviceConditionMissingPartsFull').checked;
            
            if (isMissingPartsChecked) {
                missingPartsInput.style.display = 'block';
                document.getElementById('missingPartsSpecifyFull').required = true;
            } else {
                missingPartsInput.style.display = 'none';
                document.getElementById('missingPartsSpecifyFull').required = false;
                document.getElementById('missingPartsSpecifyFull').value = '';
            }
        }

        // Calculate total service charge
        function calculateTotalDue() {
            const diagnosticFee = parseFloat(document.getElementById('rtoDiagnosticFeeFull').value) || 0;
            const cleaningFee = parseFloat(document.getElementById('rtoCleaningFeeFull').value) || 0;
            const otherCharges = parseFloat(document.getElementById('rtoOtherChargesFull').value) || 0;
            const total = diagnosticFee + cleaningFee + otherCharges;
            document.getElementById('rtoTotalDueFull').value = total.toFixed(2);
        }

        // Handle reason change
        function handleReasonChangeFull() {
            const reason = document.getElementById('rtoReasonFull').value;
            const reasonSpecifySection = document.getElementById('rtoReasonSpecifySectionFull');
            const estimatedSection = document.getElementById('rtoEstimatedSectionFull');

            if (reason === 'Other Reason with Specify') {
                reasonSpecifySection.style.display = 'block';
                document.getElementById('rtoReasonSpecifyFull').required = true;
            } else {
                reasonSpecifySection.style.display = 'none';
                document.getElementById('rtoReasonSpecifyFull').required = false;
                document.getElementById('rtoReasonSpecifyFull').value = '';
            }

            if (reason === 'Customer Declined Repair Quotation') {
                estimatedSection.style.display = 'block';
            } else {
                estimatedSection.style.display = 'none';
                document.getElementById('rtoEstimatedAmountFull').value = '';
                document.getElementById('rtoEstimatedDurationDateFull').value = '';
            }
        }

        // Submit RTO form
        function submitFullRTOForm(event) {
            event.preventDefault();

            const diagnosticId = document.getElementById('rtoFormDiagnosticId').value;
            const reason = document.getElementById('rtoReasonFull').value;
            const reasonSpecify = document.getElementById('rtoReasonSpecifyFull').value;
            const estimatedAmount = document.getElementById('rtoEstimatedAmountFull').value;
            const estimatedDurationDate = document.getElementById('rtoEstimatedDurationDateFull').value;
            const diagnosticFee = document.getElementById('rtoDiagnosticFeeFull').value;
            const cleaningFee = document.getElementById('rtoCleaningFeeFull').value;
            const otherCharges = document.getElementById('rtoOtherChargesFull').value;
            const totalDue = document.getElementById('rtoTotalDueFull').value;
            const customerName = document.getElementById('rtoCustomerName').value;
            const receivedBy = document.getElementById('rtoReceivedByFull').value;
            const technicianName = document.getElementById('rtoTechnicianName').value;

            // Get selected device conditions
            const deviceConditionCheckboxes = document.querySelectorAll('input[name="deviceConditionFull"]:checked');
            const deviceCondition = [];
            deviceConditionCheckboxes.forEach(cb => {
                deviceCondition.push(cb.value);
            });

            const missingPartsDescription = document.getElementById('deviceConditionMissingPartsFull').checked
                ? document.getElementById('missingPartsSpecifyFull').value
                : null;

            // Get digital signature
            const canvas = document.getElementById('signatureCanvasFull');
            const digitalSignature = canvas ? canvas.toDataURL() : null;

            if (!diagnosticId || !reason || !customerName || !receivedBy || deviceCondition.length === 0) {
                showNotification('Please fill in all required fields', 'error');
                return;
            }

            const rtoData = {
                diagnosticId,
                reason,
                reasonSpecify: reason === 'Other Reason with Specify' ? reasonSpecify : null,
                estimatedAmount,
                estimatedDurationDate,
                diagnosticFee,
                cleaningFee,
                otherCharges,
                totalDue,
                deviceCondition,
                missingPartsDescription,
                customerName,
                receivedBy,
                digitalSignature,
                technicianName
            };

            fetch('/api/rto/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(rtoData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showNotification('RTO submitted successfully!', 'success');
                    closeFullRTOModal();
                    loadRTOs();
                } else {
                    showNotification('Error: ' + data.message, 'error');
                }
            })
            .catch(err => {
                console.error('Error submitting RTO:', err);
                showNotification('Error submitting RTO', 'error');
            });
        }

// Signature canvas for full RTO modal
        const canvasFull = document.getElementById('signatureCanvasFull');
        if (canvasFull) {
            // Set actual canvas size to match display size
            const rect = canvasFull.getBoundingClientRect();
            canvasFull.width = rect.width;
            canvasFull.height = rect.height;
            
            const ctx = canvasFull.getContext('2d');

            function getCanvasCoords(e) {
                const rect = canvasFull.getBoundingClientRect();
                const scaleX = canvasFull.width / rect.width;
                const scaleY = canvasFull.height / rect.height;
                return {
                    x: (e.clientX - rect.left) * scaleX,
                    y: (e.clientY - rect.top) * scaleY
                };
            }

            canvasFull.addEventListener('mousedown', (e) => {
                isDrawing = true;
                const coords = getCanvasCoords(e);
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
            });

            canvasFull.addEventListener('mousemove', (e) => {
                if (!isDrawing) return;
                const coords = getCanvasCoords(e);
                ctx.lineTo(coords.x, coords.y);
                ctx.strokeStyle = '#f97316';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                ctx.stroke();
            });

            canvasFull.addEventListener('mouseup', () => isDrawing = false);
            canvasFull.addEventListener('mouseout', () => isDrawing = false);
            
            // Touch support
            canvasFull.addEventListener('touchstart', (e) => {
                e.preventDefault();
                isDrawing = true;
                const touch = e.touches[0];
                const coords = getCanvasCoords(touch);
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
            });

            canvasFull.addEventListener('touchmove', (e) => {
                e.preventDefault();
                if (!isDrawing) return;
                const touch = e.touches[0];
                const coords = getCanvasCoords(touch);
                ctx.lineTo(coords.x, coords.y);
                ctx.strokeStyle = '#f97316';
                ctx.lineWidth = 2;
                ctx.lineCap = 'round';
                ctx.lineJoin = 'round';
                ctx.stroke();
            });

            canvasFull.addEventListener('touchend', () => isDrawing = false);
        }

        function clearSignatureFull() {
            const canvas = document.getElementById('signatureCanvasFull');
            if (canvas) {
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
            }
        }

        function showNotification(message, type) {
            const notification = document.createElement('div');
            notification.className = `notification ${type}`;
            notification.innerHTML = `
                <span>${type === 'success' ? '✓' : '✕'}</span>
                <span>${message}</span>
            `;
            notification.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 15px 25px;
                border-radius: 10px;
                font-weight: 600;
                z-index: 3000;
                display: flex;
                align-items: center;
                gap: 10px;
                animation: slideIn 0.3s ease-out;
            `;
            
            if (type === 'success') {
                notification.style.background = 'rgba(34, 197, 94, 0.2)';
                notification.style.color = '#22c55e';
                notification.style.border = '1px solid rgba(34, 197, 94, 0.5)';
            } else {
                notification.style.background = 'rgba(239, 68, 68, 0.2)';
                notification.style.color = '#ef4444';
                notification.style.border = '1px solid rgba(239, 68, 68, 0.5)';
            }
            
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.style.animation = 'slideOut 0.3s ease-in forwards';
                setTimeout(() => notification.remove(), 300);
            }, 4000);
        }

        // Close modal when clicking overlay
        document.getElementById('addRTOModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeAddRTOModal();
            }
        });
    </script>
</body>
</html>
